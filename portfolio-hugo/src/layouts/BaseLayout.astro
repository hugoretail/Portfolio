---
import '../styles/global.css';
import RedThread from '../components/RedThread.svelte';
import SiteHeader from '../components/SiteHeader.astro';
import BrutalAnimatedBackground from '../components/BrutalAnimatedBackground.svelte';
import { getBaseUrl, withBase } from '../lib/withBase';

type Props = {
  title?: string;
  description?: string;
  showThread?: boolean;
  showHeaderNav?: boolean;
  showAnimatedBackground?: boolean;
  backgroundTint?: 'fire' | 'mono';
};

const {
  title = 'Hugo Retail',
  description = 'Portfolio',
  showThread = true,
  showHeaderNav = false,
  showAnimatedBackground = true,
  backgroundTint = 'fire'
} = Astro.props;

const baseImages = {
  graffitiWall: withBase('/assets/images/graffiti-wall.svg'),
  natureLoops: withBase('/assets/images/nature-loops.svg'),
  signature: withBase('/assets/images/signature.gif'),
  graffitiTexture: withBase('/assets/images/graffiti-texture.svg'),
};

const baseUrl = getBaseUrl();
const basePrefix = baseUrl === '/' ? '' : baseUrl.slice(0, -1);
const pathname = Astro.url?.pathname ?? '/';
const pathnameNoBase = basePrefix && pathname.startsWith(basePrefix)
  ? (pathname.slice(basePrefix.length) || '/')
  : pathname;

const showHomeButton = pathnameNoBase !== '/';
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Acme&family=Atomic+Age&family=Manrope:wght@200..800&family=Special+Gothic:wght@400..700&family=Zilla+Slab:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />

    <link rel="preload" as="image" href={baseImages.graffitiWall} />
    <link rel="preload" as="image" href={baseImages.natureLoops} />
    <link rel="preload" as="image" href={baseImages.signature} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-face-1.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-face-2.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-face-3.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-face-4.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-face-5.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-face-6.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-bump-1.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-bump-2.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-bump-3.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-bump-4.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-bump-5.svg')} />
    <link rel="preload" as="image" href={withBase('/assets/images/dice-bump-6.svg')} />
  </head>
  <body
    style={`--img-graffiti-wall: url('${baseImages.graffitiWall}'); --img-nature-loops: url('${baseImages.natureLoops}'); --img-graffiti-texture: url('${baseImages.graffitiTexture}');`}
    class={`min-h-screen bg-[color:var(--bg)] text-[color:var(--fg)] ${showAnimatedBackground ? 'has-animated-bg' : ''}`}
  >
    {showHomeButton ? (
      <a
        href={withBase('/')}
        class="fixed left-4 top-4 z-[70] inline-grid h-11 w-11 place-items-center brutal-border bg-black/60 text-[color:var(--fg)] shadow-[8px_8px_0_rgba(0,0,0,0.60)] transition hover:bg-black/70 hover:-translate-y-[1px] focus:outline-none focus:ring-2 focus:ring-[color:var(--acid-yellow)]/40 sm:left-5 sm:top-5"
        aria-label="Accueil"
        title="Accueil"
      >
        <span aria-hidden="true">⌂</span>
      </a>
    ) : null}

    {showAnimatedBackground ? <BrutalAnimatedBackground client:only="svelte" tint={backgroundTint} /> : null}
    {showThread ? <RedThread client:load href="/frise" /> : null}

    {showHeaderNav ? <SiteHeader /> : null}

    <div class="relative z-30">
      <slot />
    </div>
  </body>
</html>
