---
const pathname = Astro.url?.pathname ?? '/';

type NavItem = { href: string; label: string };
const nav: NavItem[] = [
  { href: '/', label: 'Accueil' },
  { href: '/moi', label: 'Moi' },
  { href: '/graffiti', label: 'Graffiti' },
  { href: '/hiphop', label: 'Hiphop' },
  { href: '/informatique', label: 'Informatique' },
  { href: '/environnement', label: 'Environnement' },
  { href: '/frise', label: 'Frise' }
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<header class="relative z-30">
  <div class="mx-auto max-w-6xl px-4 pt-6">
    <div class="brutal-border bg-black/55 px-4 py-3">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div class="font-black uppercase tracking-widest text-xs text-[color:var(--muted)]">navigation</div>
        <div class="font-display text-2xl leading-none">Hugo Retail</div>
      </div>
      <nav class="mt-3 flex flex-wrap gap-2" aria-label="Navigation principale">
        {nav.map((item) => (
          <a
            href={item.href}
            class:list={[
              'brutal-border bg-black/40 px-3 py-2 text-xs font-black uppercase tracking-widest transition',
              'hover:bg-black/60 focus:outline-none focus:ring-2 focus:ring-[color:var(--acid-yellow)]/40',
              isActive(item.href)
                ? 'text-[color:var(--acid-yellow)] border-[color:var(--acid-yellow)]'
                : 'text-[color:var(--fg)] border-[color:var(--fg)]'
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>
    </div>
  </div>
</header>
