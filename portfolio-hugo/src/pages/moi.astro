---
import BaseLayout from '../layouts/BaseLayout.astro';

const pathname = Astro.url?.pathname ?? '/';
type NavItem = { href: string; label: string };
const nav: NavItem[] = [
	{ href: '/', label: 'Accueil' },
	{ href: '/moi', label: 'Moi' },
	{ href: '/graffiti', label: 'Graffiti' },
	{ href: '/hiphop', label: 'Hiphop' },
	{ href: '/ia', label: 'IA / NLP' },
	{ href: '/litterature', label: 'Littérature' },
	{ href: '/frise', label: 'Frise' }
];

function isActive(href: string) {
	if (href === '/') return pathname === '/';
	return pathname.startsWith(href);
}

const navPositions: Array<{ x: number; y: number; r: number }> = [
	{ x: 12, y: 22, r: -3.2 },
	{ x: 78, y: 18, r: 2.2 },
	{ x: 20, y: 56, r: 1.5 },
	{ x: 70, y: 52, r: -2.3 },
	{ x: 45, y: 78, r: 3.1 },
	{ x: 8, y: 82, r: -1.3 },
	{ x: 88, y: 72, r: 1.1 }
];

const navNodes = nav.map((item, idx) => ({
	...item,
	...navPositions[idx % navPositions.length]
}));

type Piece = {
	id: string;
	label: string;
	kind: 'bio' | 'focus' | 'phrase' | 'exit' | 'stamp';
	x: number;
	y: number;
	r: number;
};

const pieces: Piece[] = [
	{ id: 'bio', label: 'DESCRIPTION', kind: 'bio', x: 44, y: 34, r: -1.8 },
	{ id: 'focus', label: 'FOCUS', kind: 'focus', x: 62, y: 62, r: 1.4 },
	{ id: 'phrase', label: 'PHRASE', kind: 'phrase', x: 30, y: 70, r: -2.2 },
	{ id: 'exit', label: 'SORTIES', kind: 'exit', x: 86, y: 40, r: 2.9 },
	{ id: 'stamp', label: 'DOSSIER', kind: 'stamp', x: 16, y: 10, r: -6.0 }
];
---

<BaseLayout title="Moi — Hugo Retail" description="À propos" showHeaderNav={false}>
	<main id="moiPage" class="moi-page relative min-h-screen overflow-hidden">
		<div class="pointer-events-none absolute inset-0 bg-graffiti opacity-[0.10]" aria-hidden="true"></div>
		<div class="pointer-events-none absolute inset-0 bg-nature opacity-[0.05]" aria-hidden="true"></div>
		<div class="paper-grain" aria-hidden="true"></div>
		<div class="noise-overlay" aria-hidden="true"></div>
		<div class="moi-strata" aria-hidden="true"></div>
		<div id="sprayLayer" class="spray-layer" aria-hidden="true"></div>

		<!-- Typography shards (bigger / more disrespectful) -->
		<div class="pointer-events-none absolute left-[-10vw] top-[4vh] rotate-[-10deg] font-display text-[24vw] leading-none text-[color:var(--fg)] opacity-[0.05]" aria-hidden="true">
			MOI
		</div>
		<div class="pointer-events-none absolute right-[-14vw] top-[38vh] rotate-[14deg] font-display text-[20vw] leading-none text-[color:var(--red-thread)] opacity-[0.06]" aria-hidden="true">
			HUGO
		</div>
		<div class="pointer-events-none absolute left-[8vw] bottom-[-6vh] rotate-[6deg] font-display text-[16vw] leading-none text-[color:var(--acid-yellow)] opacity-[0.05]" aria-hidden="true">
			RETAIL
		</div>

		<!-- Minimal header: not a bar, more like a tool overlay -->
		<header class="relative z-30 mx-auto max-w-6xl px-4 pt-6">
			<div class="flex flex-wrap items-center justify-between gap-3">
				<div class="moi-title">
					<div class="moi-kicker">PAGE / IDENTITÉ</div>
					<div class="moi-h1">MOI</div>
				</div>
				<div class="flex items-center gap-2">
					<button id="resetBtn" class="moi-btn" type="button" title="Reset layout">RESET</button>
					<button id="shuffleBtn" class="moi-btn" type="button" title="Shuffle layout">SHUFFLE</button>
					<button id="glitchBtn" class="moi-btn" type="button" aria-pressed="false" title="Mode glitch (touche G)">GLITCH</button>
					<a class="moi-btn" href="/">RETOUR</a>
				</div>
			</div>
			<p class="mt-3 max-w-3xl font-hand text-2xl leading-snug text-[color:var(--fg)] md:text-3xl">
				Je fais de la matière.
				<span class="mx-2 text-[color:var(--red-thread)]">/</span>
				Je l’organise.
				<span class="mx-2 text-[color:var(--acid-yellow)]">/</span>
				Je laisse du souffle.
			</p>
			<div class="moi-help" aria-hidden="true">
				Drag les notes. Alt+drag les liens. Touche <b>G</b> = glitch. Konami = secret.
			</div>
		</header>

		<!-- Scattered board (broken layout) -->
		<section class="relative z-20 mx-auto max-w-6xl px-4 pb-24 pt-8">
			<div id="moiBoard" class="moi-board" role="region" aria-label="Tableau (navigation + notes)">
				<svg id="moiWires" class="moi-wires" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
					<defs>
						<filter id="wireGlow" x="-40%" y="-40%" width="180%" height="180%">
							<feDropShadow dx="0" dy="0" stdDeviation="1.4" flood-color="#ff0000" flood-opacity="0.45" />
							<feDropShadow dx="0" dy="0" stdDeviation="0.7" flood-color="#ffffff" flood-opacity="0.14" />
						</filter>
					</defs>
					<g id="wirePaths" filter="url(#wireGlow)" />
				</svg>

				<!-- NAV nodes (scattered) -->
				<nav class="moi-nav" aria-label="Navigation">
					{navNodes.map((item) => (
						<a
							data-node={item.href}
							data-draggable="alt"
							href={item.href}
							class:list={[
								'node node--nav',
								isActive(item.href) ? 'node--active' : ''
							]}
							style={`--x:${item.x}; --y:${item.y}; --r:${item.r}deg;`}
						>
							<span class="node__label">{item.label}</span>
							<span class="node__sub">clic</span>
						</a>
					))}
				</nav>

				<!-- Content pieces -->
				{pieces.map((p) => (
					<section
						data-piece={p.id}
						data-node={p.id}
						data-draggable="true"
						tabindex="0"
						class:list={[`node node--${p.kind}`]}
						style={`--x:${p.x}; --y:${p.y}; --r:${p.r}deg;`}
					>
						<div class="node__header">
							<div class="node__kicker">{p.label}</div>
							<div class="node__chips" aria-hidden="true">
								<span class="chip">STICK</span>
								<span class="chip">TRACE</span>
							</div>
						</div>

						{p.kind === 'bio' ? (
							<div>
								<p class="node__text">
									Ici tu écris ta bio.
									<span class="sep">/</span>
									Ce que tu sais faire.
									<span class="sep">/</span>
									Ce que tu refuses.
									<span class="sep">/</span>
									Ce que tu veux.
								</p>
								<p class="node__micro">Astuce: fais 6 lignes max. Pas d’excuse. Pas de blabla.</p>
								<div class="node__tags">
									<span class="tag">graffiti</span>
									<span class="tag">hip-hop</span>
									<span class="tag">IA/NLP</span>
									<span class="tag">littérature</span>
								</div>
							</div>
						) : null}

						{p.kind === 'focus' ? (
							<ul class="node__list">
								<li><b>Graffiti</b> — structure + souffle</li>
								<li><b>Hip-hop</b> — coupe + boucle + texture</li>
								<li><b>IA/NLP</b> — contrainte + montage + outil</li>
								<li><b>Code</b> — interface + rythme + obsession</li>
							</ul>
						) : null}

						{p.kind === 'phrase' ? (
							<div>
								<p class="node__quote">« Je prends le chaos. Je le cadre. Je garde le souffle. »</p>
								<div class="node__micro">(à remplacer quand tu veux)</div>
							</div>
						) : null}

						{p.kind === 'exit' ? (
							<div class="node__exits">
								<a class="exit" href="/frise">FRISE →</a>
								<a class="exit" href="/graffiti">GRAFFITI →</a>
								<a class="exit" href="/ia">IA / NLP →</a>
								<a class="exit" href="/hiphop">HIP-HOP →</a>
							</div>
						) : null}

						{p.kind === 'stamp' ? (
							<div class="node__stamp">
								<div class="stamp__big">DOSSIER</div>
								<div class="stamp__small">/ identité / matières / outils /</div>
							</div>
						) : null}
					</section>
				))}
			</div>
		</section>
	</main>

	<script is:inline>
		(() => {
			const prefersReducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches ?? false;
			const page = document.getElementById('moiPage');
			const board = document.getElementById('moiBoard');
			const wiresSvg = document.getElementById('moiWires');
			const wireGroup = document.getElementById('wirePaths');
			const glitchBtn = document.getElementById('glitchBtn');
			const resetBtn = document.getElementById('resetBtn');
			const shuffleBtn = document.getElementById('shuffleBtn');
			const sprayLayer = document.getElementById('sprayLayer');
			if (!page || !board || !wiresSvg || !wireGroup) return;
			const STORAGE_KEY = 'moi.board.v3';

			const nodes = Array.from(board.querySelectorAll('[data-node]'));
			const getCenter = (el) => {
				const r = el.getBoundingClientRect();
				return { x: r.left + r.width / 2, y: r.top + r.height / 2 };
			};

			const edges = [
				['bio', '/graffiti'],
				['bio', '/ia'],
				['bio', '/hiphop'],
				['bio', '/litterature'],
				['bio', '/frise'],
				['focus', '/graffiti'],
				['phrase', '/litterature'],
				['exit', '/frise']
			];

			const byKey = new Map();
			nodes.forEach((el) => byKey.set(el.getAttribute('data-node'), el));

			const readSaved = () => {
				try {
					const raw = window.localStorage.getItem(STORAGE_KEY);
					if (!raw) return {};
					return JSON.parse(raw);
				} catch {
					return {};
				}
			};

			const writeSaved = (obj) => {
				try {
					window.localStorage.setItem(STORAGE_KEY, JSON.stringify(obj));
				} catch {
					// ignore
				}
			};

			const applyOffsetsFromStorage = () => {
				const saved = readSaved();
				nodes.forEach((el) => {
					const key = el.getAttribute('data-node');
					const o = saved?.[key];
					const dx = Number.isFinite(o?.dx) ? o.dx : 0;
					const dy = Number.isFinite(o?.dy) ? o.dy : 0;
					el.style.setProperty('--dx', `${dx}px`);
					el.style.setProperty('--dy', `${dy}px`);
				});
			};

			applyOffsetsFromStorage();

			let raf = null;
			const render = () => {
				raf = null;
				const boardRect = board.getBoundingClientRect();
				const w = Math.max(1, boardRect.width);
				const h = Math.max(1, boardRect.height);
				wiresSvg.setAttribute('viewBox', `0 0 ${w} ${h}`);
				while (wireGroup.firstChild) wireGroup.removeChild(wireGroup.firstChild);

				edges.forEach(([a, b], i) => {
					const elA = byKey.get(a);
					const elB = byKey.get(b);
					if (!elA || !elB) return;
					const ca = getCenter(elA);
					const cb = getCenter(elB);
					const ax = ca.x - boardRect.left;
					const ay = ca.y - boardRect.top;
					const bx = cb.x - boardRect.left;
					const by = cb.y - boardRect.top;

					const dx = bx - ax;
					const dy = by - ay;
					const bend = Math.min(240, Math.max(70, Math.hypot(dx, dy) * 0.25));
					const c1x = ax + dx * 0.25;
					const c1y = ay + dy * 0.25 - bend;
					const c2x = ax + dx * 0.75;
					const c2y = ay + dy * 0.75 + bend * 0.45;

					const p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
					p.setAttribute('data-a', a);
					p.setAttribute('data-b', b);
					p.setAttribute('d', `M ${ax.toFixed(2)} ${ay.toFixed(2)} C ${c1x.toFixed(2)} ${c1y.toFixed(2)}, ${c2x.toFixed(2)} ${c2y.toFixed(2)}, ${bx.toFixed(2)} ${by.toFixed(2)}`);
					p.setAttribute('fill', 'none');
					p.setAttribute('stroke', i % 3 === 0 ? 'rgba(255,0,0,0.55)' : 'rgba(255,0,0,0.28)');
					p.setAttribute('stroke-width', i % 4 === 0 ? '2.2' : '1.4');
					p.setAttribute('stroke-linecap', 'round');
					p.setAttribute('stroke-linejoin', 'round');
					p.setAttribute('stroke-dasharray', i % 2 === 0 ? '10 9' : '0');
					wireGroup.appendChild(p);
				});
			};

			const requestRender = () => {
				if (raf != null) return;
				raf = window.requestAnimationFrame(render);
			};

			const setScrollVar = () => {
				if (prefersReducedMotion) return;
				const s = Math.max(-40, Math.min(140, (window.scrollY || 0) * 0.08));
				board.style.setProperty('--scroll', String(s));
			};

			const setGlitch = (on) => {
				page.classList.toggle('moi-glitch', on);
				if (glitchBtn) glitchBtn.setAttribute('aria-pressed', on ? 'true' : 'false');
			};

			let glitchOn = false;
			glitchBtn?.addEventListener('click', () => {
				glitchOn = !glitchOn;
				setGlitch(glitchOn);
			});

			// Highlight connected wires/nodes on hover/focus
			const setHot = (key) => {
				const hotKeys = new Set([key]);
				edges.forEach(([a, b]) => {
					if (a === key) hotKeys.add(b);
					if (b === key) hotKeys.add(a);
				});

				nodes.forEach((el) => {
					const k = el.getAttribute('data-node');
					el.classList.toggle('is-hot', hotKeys.has(k));
					el.classList.toggle('is-hot-main', k === key);
				});

				const paths = wireGroup.querySelectorAll('path');
				paths.forEach((p) => {
					const a = p.getAttribute('data-a');
					const b = p.getAttribute('data-b');
					const hot = a === key || b === key;
					p.classList.toggle('wire-hot', hot);
				});
			};

			const clearHot = () => {
				nodes.forEach((el) => {
					el.classList.remove('is-hot');
					el.classList.remove('is-hot-main');
				});
				wireGroup.querySelectorAll('path').forEach((p) => p.classList.remove('wire-hot'));
			};

			nodes.forEach((el) => {
				el.addEventListener('mouseenter', () => {
					const key = el.getAttribute('data-node');
					if (key) setHot(key);
				});
				el.addEventListener('mouseleave', clearHot);
				el.addEventListener('focusin', () => {
					const key = el.getAttribute('data-node');
					if (key) setHot(key);
				});
				el.addEventListener('focusout', clearHot);
			});

			// Dragging (persisted per node)
			const isInteractiveTarget = (t) => !!t?.closest?.('a,button,input,textarea,select,label');
			let drag = null;

			const startDrag = (el, e) => {
				const key = el.getAttribute('data-node');
				if (!key) return;
				const saved = readSaved();
				const cur = saved?.[key] ?? {};
				const dx0 = Number.isFinite(cur.dx) ? cur.dx : 0;
				const dy0 = Number.isFinite(cur.dy) ? cur.dy : 0;
				drag = { el, key, x0: e.clientX, y0: e.clientY, dx0, dy0 };
				el.classList.add('is-dragging');
				try { el.setPointerCapture?.(e.pointerId); } catch {}
			};

			const moveDrag = (e) => {
				if (!drag) return;
				const dx = drag.dx0 + (e.clientX - drag.x0);
				const dy = drag.dy0 + (e.clientY - drag.y0);
				drag.el.style.setProperty('--dx', `${dx}px`);
				drag.el.style.setProperty('--dy', `${dy}px`);
				requestRender();
			};

			const endDrag = () => {
				if (!drag) return;
				drag.el.classList.remove('is-dragging');
				const key = drag.key;
				const style = getComputedStyle(drag.el);
				const dx = parseFloat(style.getPropertyValue('--dx')) || 0;
				const dy = parseFloat(style.getPropertyValue('--dy')) || 0;
				const saved = readSaved();
				saved[key] = { dx, dy };
				writeSaved(saved);
				drag = null;
				requestRender();
			};

			board.addEventListener('pointerdown', (e) => {
				const target = e.target;
				const el = target?.closest?.('[data-node]');
				if (!el || !board.contains(el)) return;
				const dragMode = el.getAttribute('data-draggable');
				if (!dragMode) return;
				if (dragMode === 'alt' && !e.altKey) return;
				if (isInteractiveTarget(target) && dragMode !== 'alt') return;
				e.preventDefault();
				startDrag(el, e);
			});

			board.addEventListener('pointermove', moveDrag);
			board.addEventListener('pointerup', endDrag);
			board.addEventListener('pointercancel', endDrag);

			// Keyboard nudge (focused node)
			board.addEventListener('keydown', (e) => {
				const el = e.target?.closest?.('[data-node]');
				if (!el || !board.contains(el)) return;
				const key = e.key;
				if (!['ArrowUp', 'ArrowDown', 'ArrowLeft', 'ArrowRight'].includes(key)) return;
				e.preventDefault();
				const step = e.shiftKey ? 12 : 3;
				const style = getComputedStyle(el);
				let dx = parseFloat(style.getPropertyValue('--dx')) || 0;
				let dy = parseFloat(style.getPropertyValue('--dy')) || 0;
				if (key === 'ArrowLeft') dx -= step;
				if (key === 'ArrowRight') dx += step;
				if (key === 'ArrowUp') dy -= step;
				if (key === 'ArrowDown') dy += step;
				el.style.setProperty('--dx', `${dx}px`);
				el.style.setProperty('--dy', `${dy}px`);
				const saved = readSaved();
				saved[el.getAttribute('data-node')] = { dx, dy };
				writeSaved(saved);
				requestRender();
			});

			resetBtn?.addEventListener('click', () => {
				try { window.localStorage.removeItem(STORAGE_KEY); } catch {}
				nodes.forEach((el) => {
					el.style.setProperty('--dx', `0px`);
					el.style.setProperty('--dy', `0px`);
				});
				requestRender();
			});

			shuffleBtn?.addEventListener('click', () => {
				const saved = readSaved();
				nodes.forEach((el) => {
					const k = el.getAttribute('data-node');
					const dx = Math.round((Math.random() - 0.5) * 220);
					const dy = Math.round((Math.random() - 0.5) * 200);
					el.style.setProperty('--dx', `${dx}px`);
					el.style.setProperty('--dy', `${dy}px`);
					saved[k] = { dx, dy };
				});
				writeSaved(saved);
				requestRender();
			});

			// Spray cursor trail (lightweight)
			if (!prefersReducedMotion && sprayLayer) {
				let last = 0;
				window.addEventListener('pointermove', (e) => {
					const now = performance.now();
					if (now - last < 24) return;
					last = now;
					const dot = document.createElement('span');
					dot.className = 'spray-dot';
					dot.style.left = `${e.clientX}px`;
					dot.style.top = `${e.clientY}px`;
					dot.style.transform = `translate(-50%,-50%) rotate(${(Math.random() * 50 - 25).toFixed(1)}deg)`;
					sprayLayer.appendChild(dot);
					window.setTimeout(() => dot.remove(), 900);
				}, { passive: true });
			}

			// Konami easter egg: 8-bit mode
			const konami = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
			let konamiIdx = 0;
			window.addEventListener('keydown', (e) => {
				const k = e.key;
				const expected = konami[konamiIdx];
				if (!expected) return;
				if (k === expected || k.toLowerCase() === expected) {
					konamiIdx++;
					if (konamiIdx >= konami.length) {
						konamiIdx = 0;
						page.classList.toggle('moi-8bit');
						requestRender();
					}
				} else {
					konamiIdx = 0;
				}
			});

			window.addEventListener('resize', requestRender);
			window.addEventListener('scroll', () => {
				setScrollVar();
				requestRender();
			}, { passive: true });

			window.addEventListener('keydown', (e) => {
				if (e.key.toLowerCase() === 'g') {
					glitchOn = !glitchOn;
					setGlitch(glitchOn);
				}
			});

			setScrollVar();
			requestRender();
		})();
	</script>

	<style>
		.moi-page {
			--paper: rgba(0, 0, 0, 0.55);
			--paper2: rgba(0, 0, 0, 0.42);
		}

		.spray-layer {
			position: fixed;
			inset: 0;
			pointer-events: none;
			z-index: 18;
			mix-blend-mode: screen;
		}

		.spray-dot {
			position: absolute;
			width: 14px;
			height: 14px;
			border-radius: 999px;
			background: radial-gradient(circle at 35% 35%, rgba(255, 0, 0, 0.55), rgba(255, 0, 0, 0.0) 68%);
			filter: blur(0.2px);
			opacity: 0.9;
			animation: sprayFade 0.9s ease-out forwards;
		}

		@keyframes sprayFade {
			0% { opacity: 0.9; transform: translate(-50%,-50%) scale(1); }
			100% { opacity: 0; transform: translate(-50%,-50%) scale(1.9); }
		}

		.moi-strata {
			position: absolute;
			inset: 0;
			pointer-events: none;
			background:
				linear-gradient(180deg, rgba(255, 0, 0, 0.08), transparent 26%),
				linear-gradient(180deg, transparent 40%, rgba(255, 230, 0, 0.05) 65%, transparent 92%),
				repeating-linear-gradient(0deg, rgba(246, 246, 246, 0.03) 0 1px, transparent 1px 14px);
			opacity: 0.85;
			mix-blend-mode: overlay;
		}

		.moi-title {
			line-height: 1;
		}

		.moi-kicker {
			font-size: 10px;
			letter-spacing: 0.35em;
			text-transform: uppercase;
			font-weight: 900;
			color: var(--muted);
		}

		.moi-h1 {
			font-family: var(--font-display, 'Bebas Neue', system-ui, sans-serif);
			font-weight: 900;
			letter-spacing: 0.02em;
			font-size: clamp(44px, 8vw, 90px);
			text-shadow: 14px 14px 0 rgba(255, 0, 0, 0.12);
		}

		.moi-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 8px;
			padding: 10px 12px;
