---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getBaseUrl, withBase } from '../lib/withBase';

const baseUrl = getBaseUrl();
const basePrefix = baseUrl === '/' ? '' : baseUrl.slice(0, -1);

const pathname = Astro.url?.pathname ?? '/';
const pathnameNoBase = basePrefix && pathname.startsWith(basePrefix)
	? (pathname.slice(basePrefix.length) || '/')
	: pathname;
type NavItem = { href: string; label: string };
const nav: NavItem[] = [
	{ href: '/', label: 'Accueil' },
	{ href: '/moi', label: 'Moi' },
	{ href: '/graffiti', label: 'Graffiti' },
	{ href: '/hiphop', label: 'Hip-hop' },
	{ href: '/informatique', label: 'Informatique' },
	{ href: '/environnement', label: 'Environnement' },
	{ href: '/frise', label: 'Frise' }
];

function isActive(href: string) {
	if (href === '/') return pathnameNoBase === '/';
	return pathnameNoBase.startsWith(href);
}

const navPositions: Array<{ x: number; y: number; r: number }> = [
	// Accueil / Moi stay as-is (no extra notes)
	{ x: 12, y: 12, r: -3.2 },
	{ x: 86, y: 12, r: 2.2 },
	// Sections
	{ x: 12, y: 44, r: -2.0 }, // Graffiti
	{ x: 90, y: 44, r: 2.0 },  // Hiphop
	{ x: 54, y: 63, r: 2.8 },  // Informatique
	{ x: 18, y: 74, r: -1.4 }, // Environnement
	{ x: 88, y: 66, r: 1.1 }   // Frise
];

const navNodes = nav.map((item, idx) => ({
	...item,
	...navPositions[idx % navPositions.length]
}));

type Piece = {
	id: string;
	label: string;
	kind: 'bio' | 'focus' | 'stamp' | 'note';
	x: number;
	y: number;
	r: number;
	title?: string;
	text?: string;
	forKey?: string;
};

const piecesCore: Piece[] = [
	{ id: 'bio', label: 'DESCRIPTION', kind: 'bio', x: 50, y: 14, r: -1.8 },
	{ id: 'focus', label: 'FOCUS', kind: 'focus', x: 22, y: 64, r: 1.2 },
	{ id: 'stamp', label: '<><><>', kind: 'stamp', x: 5, y: 4, r: -6.0 }
];

// One extra note per section label (except Accueil/Moi)
const piecesNotes: Piece[] = [
	{
		id: 'note-graffiti',
		label: 'NOTE',
		kind: 'note',
		x: 32,
		y: 44,
		r: 1.4,
		forKey: '/graffiti',
		text: 'Cette odeur de la 94 Montana, incroyable...'
	},
	{
		id: 'note-hiphop',
		label: 'NOTE',
		kind: 'note',
		x: 68,
		y: 44,
		r: -1.6,
		forKey: '/hiphop',
		text: 'Popping, dissociations, et du groove!'
	},
	{
		id: 'note-ia',
		label: 'FOCUS',
		kind: 'note',
		x: 66,
		y: 72,
		r: 2.2,
		forKey: '/informatique',
		text: 'Est-ce vraiment utile de (vibe) coder ça ?'
	},
	{
		id: 'note-environnement',
		label: 'NOTE',
		kind: 'note',
		x: 10,
		y: 86,
		r: -2.6,
		forKey: '/environnement',
		text: "Ma motivation écologique."
	},
	{
		id: 'note-frise',
		label: 'NOTE',
		kind: 'note',
		x: 74,
		y: 86,
		r: 1.0,
		forKey: '/frise',
		text: 'Cool ce format !'
	}
];

const pieces: Piece[] = [...piecesCore, ...piecesNotes];
---

<BaseLayout title="Moi — Hugo Retail" description="À propos" showHeaderNav={false}>
	<main id="moiPage" class="moi-page relative min-h-screen overflow-hidden">
		<div class="pointer-events-none absolute inset-0 bg-graffiti opacity-[0.10]" aria-hidden="true"></div>
		<div class="pointer-events-none absolute inset-0 bg-nature opacity-[0.05]" aria-hidden="true"></div>
		<div class="paper-grain" aria-hidden="true"></div>
		<div class="noise-overlay" aria-hidden="true"></div>
		<div class="moi-strata" aria-hidden="true"></div>


		<!-- Typography shards (bigger / more disrespectful) -->
		<div class="pointer-events-none absolute left-[-10vw] top-[4vh] rotate-[-10deg] font-display text-[24vw] leading-none text-[color:var(--fg)] opacity-[0.05]" aria-hidden="true">
			MOI
		</div>
		<div class="pointer-events-none absolute right-[-14vw] top-[38vh] rotate-[14deg] font-display text-[20vw] leading-none text-[color:var(--red-thread)] opacity-[0.06]" aria-hidden="true">
			HUGO
		</div>
		<div class="pointer-events-none absolute left-[8vw] bottom-[-6vh] rotate-[6deg] font-display text-[16vw] leading-none text-[color:var(--acid-yellow)] opacity-[0.05]" aria-hidden="true">
			RETAIL
		</div>

		<!-- Minimal header: not a bar, more like a tool overlay -->
		<header class="relative z-30 mx-auto max-w-6xl px-4 pt-6">
			<div class="flex flex-wrap items-center justify-between gap-3">
				<div class="moi-title">
					<div class="moi-kicker">Le tableau</div>
					<div class="moi-h1">MOI</div>
				</div>
			</div>
			<p class="mt-3 max-w-3xl font-hand text-2xl leading-snug text-[color:var(--fg)] md:text-3xl">
				Une façon d'organiser ma <span class="text-[color:var(--acid-yellow)]">personne</span>.
				Visitez les pages <span class="text-[color:var(--red-thread)]">jaunes</span> !
			</p>
			<p class="moi-help">
				<span class="help-chip">Jaune</span> = pages visitables · <span class="help-chip help-chip--note">Post-it</span> = notes.
			</p>
		</header>

		<!-- Scattered board (broken layout) -->
		<section class="relative z-20 mx-auto max-w-6xl px-4 pb-24 pt-8">
			<div id="moiBoard" class="moi-board" role="region" aria-label="Tableau (navigation + notes)">
				<svg id="moiWires" class="moi-wires" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
					<defs>
						<filter id="wireGlow" x="-40%" y="-40%" width="180%" height="180%">
							<feDropShadow dx="0" dy="0" stdDeviation="1.4" flood-color="#ff0000" flood-opacity="0.45" />
							<feDropShadow dx="0" dy="0" stdDeviation="0.7" flood-color="#ffffff" flood-opacity="0.14" />
						</filter>
					</defs>
					<g id="wirePaths" filter="url(#wireGlow)" />
				</svg>

				<!-- NAV nodes (scattered) -->
				<nav class="moi-nav" aria-label="Navigation">
					{navNodes.map((item) => (
						// eslint-disable-next-line astro/no-set-html-directive
						<a
							data-node={item.href}
								href={withBase(item.href)}
							class:list={[
								'node node--nav',
								(item.href !== '/moi') ? 'node--linkout' : '',
								isActive(item.href) ? 'node--active' : ''
							]}
							style={`--x:${item.x}; --y:${item.y}; --r:${item.r}deg;`}
						>
							<span class="node__label">{item.label}</span>
							<span class="node__sub">{(item.href !== '/' && item.href !== '/moi') ? 'visiter' : ''}</span>
							{(item.href !== '/' && item.href !== '/moi') ? <span class="node__go" aria-hidden="true">↗</span> : null}
						</a>
					))}
				</nav>

				<!-- Content pieces -->
				{pieces.map((p) => (
					<section
						data-piece={p.id}
						data-node={p.kind === 'note' ? `note:${p.forKey}` : p.id}
						tabindex="0"
						class:list={[`node node--${p.kind}`]}
						style={`--x:${p.x}; --y:${p.y}; --r:${p.r}deg;`}
					>
						<div class="node__header">
							<div class="node__kicker">{p.label}</div>
							<div class="node__chips" aria-hidden="true">
								<span class="chip">POST-IT</span>
							</div>
						</div>

						{p.kind === 'bio' ? (
							<div>
								<p class="node__text">
									Je mélange mes passions à mes compétences.
									Pour l'échange culturel.
									Pour l'environnement.
									Et pour moi.
								</p>
							</div>
						) : null}

						{p.kind === 'focus' ? (
							<ul class="node__list">
								<li><b>Brouillon</b> — lettres bâton + outlines</li>
								<li><b>Fill-in</b> — Lettres + background + 3D</li>
								<li><b>Détails</b> — Textures + ombres</li>
								<li><b>Finish</b> — Outline + frog + reflets</li>
							</ul>
						) : null}

						{p.kind === 'note' ? (
							<div class="node__note">
								<div class="node__noteTitle">{p.title}</div>
								<p class="node__noteText">{p.text}</p>
							</div>
						) : null}

						{p.kind === 'stamp' ? (
							<div class="node__stamp">
								<div class="stamp__big">DOSSIER</div>
								<div class="stamp__small">>>>>>>>>>>>>>>>>></div>
							</div>
						) : null}
					</section>
				))}
			</div>
		</section>
	</main>

	<script is:inline>
		(() => {
			const prefersReducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches ?? false;
			const page = document.getElementById('moiPage');
			const board = document.getElementById('moiBoard');
			const wiresSvg = document.getElementById('moiWires');
			const wireGroup = document.getElementById('wirePaths');
			if (!page || !board || !wiresSvg || !wireGroup) return;

			const nodes = Array.from(board.querySelectorAll('[data-node]'));
			const getCenter = (el) => {
				const r = el.getBoundingClientRect();
				return { x: r.left + r.width / 2, y: r.top + r.height / 2 };
			};

			const edges = [
				['bio', '/graffiti'],
				['bio', '/informatique'],
				['bio', '/hiphop'],
				['bio', '/environnement'],
				['bio', '/frise'],
				['focus', '/graffiti'],
				// Bind each section label to its own note
				['/graffiti', 'note:/graffiti'],
				['/hiphop', 'note:/hiphop'],
				['/informatique', 'note:/informatique'],
				['/environnement', 'note:/environnement'],
				['/frise', 'note:/frise']
			];

			const byKey = new Map();
			nodes.forEach((el) => byKey.set(el.getAttribute('data-node'), el));

			// Pre-create wire paths once, then only update geometry (much cheaper).
			const paths = edges.map(([a, b], i) => {
				const p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
				p.setAttribute('data-a', a);
				p.setAttribute('data-b', b);
				p.setAttribute('fill', 'none');
				p.setAttribute('stroke', i % 3 === 0 ? 'rgba(255,0,0,0.55)' : 'rgba(255,0,0,0.28)');
				p.setAttribute('stroke-width', i % 4 === 0 ? '2.2' : '1.4');
				p.setAttribute('stroke-linecap', 'round');
				p.setAttribute('stroke-linejoin', 'round');
				p.setAttribute('stroke-dasharray', i % 2 === 0 ? '10 9' : '0');
				wireGroup.appendChild(p);
				return p;
			});

			let raf = null;
			let lastW = 0;
			let lastH = 0;
			const render = () => {
				raf = null;
				const boardRect = board.getBoundingClientRect();
				const w = Math.max(1, boardRect.width);
				const h = Math.max(1, boardRect.height);
				if (w !== lastW || h !== lastH) {
					lastW = w;
					lastH = h;
					wiresSvg.setAttribute('viewBox', `0 0 ${w} ${h}`);
				}

				// Cache rects per element for this render.
				const rectCache = new Map();
				const getCenterCached = (el) => {
					let c = rectCache.get(el);
					if (c) return c;
					const r = el.getBoundingClientRect();
					c = { x: r.left + r.width / 2, y: r.top + r.height / 2 };
					rectCache.set(el, c);
					return c;
				};

				edges.forEach(([a, b], i) => {
					const elA = byKey.get(a);
					const elB = byKey.get(b);
					const p = paths[i];
					if (!p) return;
					if (!elA || !elB) {
						p.style.display = 'none';
						return;
					}
					p.style.display = '';

					const ca = getCenterCached(elA);
					const cb = getCenterCached(elB);
					const ax = ca.x - boardRect.left;
					const ay = ca.y - boardRect.top;
					const bx = cb.x - boardRect.left;
					const by = cb.y - boardRect.top;

					const dx = bx - ax;
					const dy = by - ay;
					const bend = Math.min(240, Math.max(70, Math.hypot(dx, dy) * 0.25));
					const c1x = ax + dx * 0.25;
					const c1y = ay + dy * 0.25 - bend;
					const c2x = ax + dx * 0.75;
					const c2y = ay + dy * 0.75 + bend * 0.45;

					p.setAttribute('d', `M ${ax.toFixed(2)} ${ay.toFixed(2)} C ${c1x.toFixed(2)} ${c1y.toFixed(2)}, ${c2x.toFixed(2)} ${c2y.toFixed(2)}, ${bx.toFixed(2)} ${by.toFixed(2)}`);
				});
			};

			const requestRender = () => {
				if (raf != null) return;
				raf = window.requestAnimationFrame(render);
			};

			// Highlight connected wires/nodes on hover/focus
			const setHot = (key) => {
				const hotKeys = new Set([key]);
				edges.forEach(([a, b]) => {
					if (a === key) hotKeys.add(b);
					if (b === key) hotKeys.add(a);
				});

				nodes.forEach((el) => {
					const k = el.getAttribute('data-node');
					el.classList.toggle('is-hot', hotKeys.has(k));
					el.classList.toggle('is-hot-main', k === key);
				});

				paths.forEach((p) => {
					const a = p.getAttribute('data-a');
					const b = p.getAttribute('data-b');
					const hot = a === key || b === key;
					p.classList.toggle('wire-hot', hot);
				});
			};

			const clearHot = () => {
				nodes.forEach((el) => {
					el.classList.remove('is-hot');
					el.classList.remove('is-hot-main');
				});
				paths.forEach((p) => p.classList.remove('wire-hot'));
			};

			nodes.forEach((el) => {
				el.addEventListener('mouseenter', () => {
					const key = el.getAttribute('data-node');
					if (key) setHot(key);
				});
				el.addEventListener('mouseleave', clearHot);
				el.addEventListener('focusin', () => {
					const key = el.getAttribute('data-node');
					if (key) setHot(key);
				});
				el.addEventListener('focusout', clearHot);
			});


			// Konami easter egg: 8-bit mode
			const konami = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
			let konamiIdx = 0;
			window.addEventListener('keydown', (e) => {
				const k = e.key;
				const expected = konami[konamiIdx];
				if (!expected) return;
				if (k === expected || k.toLowerCase() === expected) {
					konamiIdx++;
					if (konamiIdx >= konami.length) {
						konamiIdx = 0;
						page.classList.toggle('moi-8bit');
						requestRender();
					}
				} else {
					konamiIdx = 0;
				}
			});

			window.addEventListener('resize', requestRender);
			document.fonts?.ready?.then?.(requestRender);
			requestRender();
		})();
	</script>

	<style>
		.moi-page {
			--paper: rgba(0, 0, 0, 0.55);
			--paper2: rgba(0, 0, 0, 0.42);
		}

		.moi-strata {
			position: absolute;
			inset: 0;
			pointer-events: none;
			background:
				linear-gradient(180deg, rgba(255, 0, 0, 0.08), transparent 26%),
				linear-gradient(180deg, transparent 40%, rgba(255, 230, 0, 0.05) 65%, transparent 92%),
				repeating-linear-gradient(0deg, rgba(246, 246, 246, 0.03) 0 1px, transparent 1px 14px);
			opacity: 0.85;
			mix-blend-mode: overlay;
		}

		.moi-title {
			line-height: 1;
		}

		.moi-kicker {
			font-size: 10px;
			letter-spacing: 0.35em;
			text-transform: uppercase;
			font-weight: 900;
			color: var(--muted);
		}

		.moi-h1 {
			font-family: var(--font-display, 'Acme', system-ui, sans-serif);
			font-weight: 900;
			letter-spacing: 0.02em;
			font-size: clamp(44px, 8vw, 90px);
			text-shadow: 14px 14px 0 rgba(255, 0, 0, 0.12);
		}

		.moi-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			gap: 8px;
			padding: 10px 12px;
			font-weight: 900;
			font-size: 11px;
			letter-spacing: 0.22em;
			text-transform: uppercase;
			background: rgba(0, 0, 0, 0.55);
			border: 2px solid var(--fg);
			box-shadow: 6px 6px 0 rgba(246, 246, 246, 0.12);
		}

		.moi-btn:hover {
			background: rgba(0, 0, 0, 0.78);
		}

		.moi-board {
			position: relative;
			min-height: min(1200px, 150vh);
			border: 2px dashed rgba(246, 246, 246, 0.18);
			background:
				repeating-linear-gradient(90deg, rgba(246, 246, 246, 0.03) 0 1px, transparent 1px 120px),
				repeating-linear-gradient(0deg, rgba(255, 0, 0, 0.028) 0 1px, transparent 1px 90px);
		}

		.moi-wires {
			position: absolute;
			inset: 0;
			width: 100%;
			height: 100%;
			pointer-events: none;
			opacity: 0.95;
		}

		.node {
			position: absolute;
			left: calc(var(--x) * 1%);
			top: calc(var(--y) * 1%);
			cursor: pointer;
			transform: translate(-50%, -50%) rotate(var(--r, 0deg));
			transform-origin: center;
			max-width: min(520px, 86vw);
			color: var(--fg);
			background: var(--paper);
			border: 2px solid var(--fg);
			box-shadow: 10px 10px 0 rgba(0, 0, 0, 0.55);
			padding: 14px 14px 12px;
			clip-path: polygon(2% 2%, 98% 0, 100% 86%, 94% 100%, 2% 98%, 0 18%);
			backdrop-filter: none;
		}

		.node:hover {
			filter: drop-shadow(0 0 12px rgba(255, 0, 0, 0.22));
		}

		.is-hot {
			border-color: rgba(255, 0, 0, 0.85);
			box-shadow: 12px 12px 0 rgba(255, 0, 0, 0.10);
		}

		.is-hot-main {
			outline: 2px solid rgba(255, 230, 0, 0.55);
			outline-offset: 5px;
		}

		.node:focus-within {
			outline: 2px solid rgba(255, 230, 0, 0.55);
			outline-offset: 4px;
		}

		.node__header {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
			gap: 10px;
		}

		.node__kicker {
			font-weight: 900;
			font-size: 10px;
			letter-spacing: 0.35em;
			text-transform: uppercase;
			color: var(--muted);
		}

		.node__chips {
			display: flex;
			gap: 6px;
		}

		.chip {
			font-weight: 900;
			font-size: 9px;
			letter-spacing: 0.28em;
			text-transform: uppercase;
			padding: 4px 6px;
			border: 1px solid rgba(246, 246, 246, 0.25);
			opacity: 0.7;
		}

		.node--nav {
			padding: 14px 16px;
			max-width: none;
			text-decoration: none;
			background: rgba(0, 0, 0, 0.48);
			clip-path: polygon(0 10%, 96% 0, 100% 90%, 92% 100%, 4% 94%);
		}

		.node--nav.node--linkout {
			border-color: rgba(255, 230, 0, 0.75);
			box-shadow: 10px 10px 0 rgba(255, 230, 0, 0.10);
			padding-right: 44px;
			background:
				linear-gradient(180deg, rgba(255, 230, 0, 0.08), transparent 40%),
				rgba(0, 0, 0, 0.58);
			filter: drop-shadow(0 0 16px rgba(255, 230, 0, 0.08));
		}

		.node--nav.node--linkout .node__label {
			text-shadow: 0 0 10px rgba(255, 230, 0, 0.08);
		}

		.node--nav.node--linkout .node__sub {
			color: rgba(255, 230, 0, 0.80);
		}

		.node__go {
			position: absolute;
			right: 10px;
			top: 50%;
			transform: translateY(-50%);
			width: 22px;
			height: 22px;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			border: 2px solid rgba(255, 230, 0, 0.65);
			background: rgba(0, 0, 0, 0.55);
			font-weight: 900;
			line-height: 1;
			color: rgba(255, 230, 0, 0.90);
			box-shadow: 6px 6px 0 rgba(0, 0, 0, 0.55);
			pointer-events: none;
		}

		@media (prefers-reduced-motion: no-preference) {
			.node--nav.node--linkout {
				animation: linkPulse 1.8s ease-in-out infinite;
			}
			@keyframes linkPulse {
				0%, 100% { filter: drop-shadow(0 0 14px rgba(255, 230, 0, 0.06)); }
				50% { filter: drop-shadow(0 0 22px rgba(255, 230, 0, 0.13)); }
			}
		}

		.node--nav .node__label {
			font-weight: 900;
			letter-spacing: 0.22em;
			text-transform: uppercase;
			font-size: 13px;
			display: block;
		}

		.node--nav .node__sub {
			display: block;
			margin-top: 4px;
			font-size: 11px;
			color: rgba(246, 246, 246, 0.7);
			letter-spacing: 0.12em;
			text-transform: uppercase;
		}

		.node--active {
			border-color: var(--acid-yellow);
			box-shadow: 10px 10px 0 rgba(255, 230, 0, 0.12);
		}

		.node--bio {
			width: min(560px, 90vw);
			background: rgba(0, 0, 0, 0.60);
		}

		.node__text {
			margin-top: 10px;
			font-family: var(--font-ui);
			font-size: clamp(20px, 3vw, 36px);
			line-height: 1.15;
			color: var(--fg);
		}

		.node__micro {
			margin-top: 8px;
