---
import BaseLayout from '../layouts/BaseLayout.astro';

const pathname = Astro.url?.pathname ?? '/';
type NavItem = { href: string; label: string; tag?: string };

const nav: NavItem[] = [
	{ href: '/', label: 'Accueil', tag: '00' },
	{ href: '/moi', label: 'Moi', tag: '01' },
	{ href: '/graffiti', label: 'Graffiti', tag: 'A' },
	{ href: '/hiphop', label: 'Hiphop', tag: 'B' },
	{ href: '/ia', label: 'IA / NLP', tag: 'C' },
	{ href: '/litterature', label: 'Littérature', tag: 'D' },
	{ href: '/frise', label: 'Frise', tag: 'E' }
];

const tracks: Array<{ id: string; label: string; href: string; note: string }> = [
	{ id: 'A', label: 'GRAFFITI', href: '/graffiti', note: 'mur / rythme / précision' },
	{ id: 'B', label: 'HIP-HOP', href: '/hiphop', note: 'coupe / boucle / texture' },
	{ id: 'C', label: 'IA / NLP', href: '/ia', note: 'contrainte / montage / outil' },
	{ id: 'D', label: 'LITTÉRATURE', href: '/litterature', note: 'souffle / phrase / cadre' },
	{ id: 'E', label: 'FRISE', href: '/frise', note: 'timeline / trace / parcours' }
];

function isActive(href: string) {
	if (href === '/') return pathname === '/';
	return pathname.startsWith(href);
}
---

<BaseLayout title="Moi — Hugo Retail" description="À propos" showHeaderNav={false}>
	<main id="moiCassette" class="moi-cassette">
		<div class="moi-bg" aria-hidden="true"></div>
		<div class="paper-grain" aria-hidden="true"></div>
		<div class="noise-overlay" aria-hidden="true"></div>

		<header class="moi-top" aria-label="En-tête">
			<div class="moi-brand">
				<div class="kicker">SIDE A</div>
				<h1 class="title">MOI</h1>
				<div class="sub">Hugo Retail — cassette d’identité</div>
			</div>
			<nav class="moi-mini-nav" aria-label="Navigation rapide">
				{nav.map((item) => (
					<a class:list={["mini", isActive(item.href) ? "is-active" : ""]} href={item.href}>
						<span class="miniTag" aria-hidden="true">{item.tag}</span>
						{item.label}
					</a>
				))}
			</nav>
		</header>

		<section class="deck" aria-label="Deck cassette">
			<div class="deckGrid">
				<!-- CASSETTE -->
				<section class="cassette" aria-label="Cassette">
					<div class="cassetteShell" aria-hidden="true">
						<div class="screws"></div>
						<div class="window">
							<div class="tape"></div>
							<div class="reel reelL"><div class="hub"></div></div>
							<div class="reel reelR"><div class="hub"></div></div>
						</div>
						<div class="label">
							<div class="labelRow">
								<div class="labelTitle">IDENTITÉ</div>
								<div class="labelCode">HR-01</div>
							</div>
							<div class="labelText">
								Je fabrique des images, des systèmes et des gestes.
								<span class="sep">/</span>
								Brutaliste, mais vivant.
							</div>
							<div class="labelMeta">
								<span class="pill">NO COPY</span>
								<span class="pill">RAW</span>
								<span class="pill">FIELD</span>
								<span class="pill">TOOLS</span>
							</div>
						</div>
					</div>

					<!-- TRACKLIST in the cassette area (not a normal menu) -->
					<div class="tracklist" aria-label="Pistes">
						<div class="trackHeader">
							<div class="k">TRACKLIST</div>
							<div class="led" id="recLed" aria-hidden="true"></div>
						</div>
						<ol class="tracks">
							{tracks.map((t) => (
								<li>
									<a class="track" href={t.href} data-track={t.id}>
										<span class="trkId">{t.id}</span>
										<span class="trkName">{t.label}</span>
										<span class="trkNote">{t.note}</span>
									</a>
								</li>
							))}
						</ol>
					</div>

					<!-- CONTROLS -->
					<div class="controls" aria-label="Contrôles">
						<button id="btnPlay" class="btn btnPlay" type="button" aria-pressed="false">
							PLAY
						</button>
						<button id="btnStop" class="btn" type="button">STOP</button>
						<button id="btnRec" class="btn btnRec" type="button" aria-pressed="false">REC</button>
						<a class="btn btnEject" href="/" title="Eject / retour">EJECT</a>

						<label class="knob" for="speed">
							<span class="knobLabel">SPEED</span>
							<input id="speed" type="range" min="0" max="100" value="52" />
						</label>
						<div class="help" aria-hidden="true">Space=play · R=rec · 1..5=tracks</div>
					</div>
				</section>

				<!-- LINER NOTES -->
				<section class="notes" aria-label="Liner notes">
					<div class="notesTop">
						<div class="stamp">INSERT</div>
						<div class="notesKicker">DESCRIPTION (à remplir)</div>
					</div>
					<div class="notesBody">
						<p class="bio" id="bioText">
							Ici tu poses ton texte.
							<span class="sep">/</span>
							Court.
							<span class="sep">/</span>
							Tranchant.
							<span class="sep">/</span>
							Vrai.
						</p>
						<div class="cols">
							<div>
								<div class="h">Focus</div>
								<ul class="list">
									<li><b>Rue</b> → composition</li>
									<li><b>Son</b> → découpe</li>
									<li><b>Langage</b> → structure</li>
									<li><b>Interfaces</b> → rythme</li>
								</ul>
							</div>
							<div>
								<div class="h">Tags</div>
								<div class="tags">
									<span class="tag">spray</span>
									<span class="tag">stylo</span>
									<span class="tag">code</span>
									<span class="tag">3D</span>
									<span class="tag">NLP</span>
								</div>
							</div>
						</div>
						<div class="credits">
							<div class="h">Credits</div>
							<div class="mono">
								REC = mode “brut”.
								<br />PLAY = vie.
								<br />STOP = silence.
							</div>
						</div>
					</div>
				</section>
			</div>
		</section>
	</main>

	<script is:inline>
		(() => {
			const page = document.getElementById('moiCassette');
			const btnPlay = document.getElementById('btnPlay');
			const btnStop = document.getElementById('btnStop');
			const btnRec = document.getElementById('btnRec');
			const speed = document.getElementById('speed');
			const recLed = document.getElementById('recLed');
			const bioText = document.getElementById('bioText');
			if (!page) return;

			const prefersReducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches ?? false;
			const STORAGE = 'moi.cassette.v1';

			const readState = () => {
				try {
					return JSON.parse(window.localStorage.getItem(STORAGE) || '{}');
				} catch {
					return {};
				}
			};
			const writeState = (s) => {
				try {
					window.localStorage.setItem(STORAGE, JSON.stringify(s));
				} catch {
					// ignore
				}
			};

			const state = { playing: false, rec: false, speed: 52, ...readState() };
			if (prefersReducedMotion) state.playing = false;
			if (speed) speed.value = String(state.speed ?? 52);

			const apply = () => {
				page.classList.toggle('is-playing', !!state.playing);
				page.classList.toggle('is-rec', !!state.rec);
				page.style.setProperty('--spd', String((state.speed ?? 52) / 100));
				btnPlay?.setAttribute('aria-pressed', state.playing ? 'true' : 'false');
				btnRec?.setAttribute('aria-pressed', state.rec ? 'true' : 'false');
				recLed?.classList.toggle('on', !!state.rec);

				if (bioText) {
					bioText.textContent = state.rec
						? 'Je fais. Je coupe. Je colle. Je recommence. / Pas de filtre. / Pas de discours.'
						: 'Ici tu poses ton texte. / Court. / Tranchant. / Vrai.';
				}
			};

			const save = () => writeState({ playing: state.playing, rec: state.rec, speed: state.speed });

			const playToggle = () => {
				if (prefersReducedMotion) return;
				state.playing = !state.playing;
				apply();
				save();
			};
			const stop = () => {
				state.playing = false;
				apply();
				save();
			};
			const recToggle = () => {
				state.rec = !state.rec;
				apply();
				save();
			};

			btnPlay?.addEventListener('click', playToggle);
			btnStop?.addEventListener('click', stop);
			btnRec?.addEventListener('click', recToggle);
			speed?.addEventListener('input', (e) => {
				state.speed = Number(e.target?.value ?? 52);
				apply();
				save();
			});

			window.addEventListener('keydown', (e) => {
				if (e.key === ' ' || e.code === 'Space') {
					e.preventDefault();
					playToggle();
					return;
				}
				if (e.key.toLowerCase() === 'r') {
					recToggle();
					return;
				}
				if (e.key.toLowerCase() === 's') {
					stop();
					return;
				}
				// quick track jump 1..5
				const idx = Number(e.key) - 1;
				if (idx >= 0 && idx < 5) {
					const href = ['\/graffiti','\/hiphop','\/ia','\/litterature','\/frise'][idx];
					window.location.assign(href);
				}
			});

			apply();
		})();
	</script>

	<style>
		.moi-cassette {
			--bg: var(--bg);
			--fg: var(--fg);
			--muted: var(--muted);
			--red: var(--red-thread);
			--acid: var(--acid-yellow);
			--spd: 0.52;
			min-height: 100vh;
			position: relative;
			padding-bottom: 64px;
			overflow: hidden;
		}

		.moi-bg {
			position: absolute;
			inset: 0;
			pointer-events: none;
			background:
				repeating-linear-gradient(90deg, rgba(246, 246, 246, 0.03) 0 1px, transparent 1px 160px),
				repeating-linear-gradient(0deg, rgba(255, 0, 0, 0.025) 0 1px, transparent 1px 22px),
				radial-gradient(circle at 16% 24%, rgba(255, 0, 0, 0.10), transparent 46%),
				radial-gradient(circle at 78% 72%, rgba(255, 230, 0, 0.06), transparent 54%);
			opacity: 0.9;
			mix-blend-mode: overlay;
		}

		.moi-top {
			position: relative;
			z-index: 3;
			max-width: 1100px;
			margin: 0 auto;
			padding: 24px 16px 8px;
			display: grid;
			gap: 12px;
			grid-template-columns: 1fr;
		}

		.moi-brand .kicker {
			font-weight: 900;
			letter-spacing: 0.35em;
			text-transform: uppercase;
			font-size: 10px;
			color: rgba(246, 246, 246, 0.62);
		}

		.moi-brand .title {
			margin: 6px 0 0;
			font-family: 'Bebas Neue', system-ui, sans-serif;
			font-size: clamp(56px, 9vw, 120px);
			line-height: 0.9;
			letter-spacing: 0.04em;
			text-shadow: 16px 16px 0 rgba(255, 0, 0, 0.12);
		}

		.moi-brand .sub {
			margin-top: 6px;
			font-weight: 900;
			letter-spacing: 0.22em;
			text-transform: uppercase;
			font-size: 11px;
			color: rgba(246, 246, 246, 0.70);
		}

		.moi-mini-nav {
			display: flex;
			flex-wrap: wrap;
			gap: 8px;
			align-items: center;
		}

		.mini {
			display: inline-flex;
			gap: 10px;
			align-items: center;
			padding: 10px 12px;
			border: 2px solid var(--fg);
			background: rgba(0, 0, 0, 0.55);
			box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.55);
			text-decoration: none;
			font-weight: 900;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			font-size: 11px;
		}

		.mini:hover {
			background: rgba(0, 0, 0, 0.82);
		}

		.mini:focus-visible {
			outline: 2px solid rgba(255, 230, 0, 0.6);
			outline-offset: 4px;
		}

		.miniTag {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 28px;
			height: 22px;
			border: 2px solid rgba(246, 246, 246, 0.35);
			font-size: 10px;
			letter-spacing: 0.18em;
			color: rgba(246, 246, 246, 0.78);
		}

		.mini.is-active {
			border-color: var(--acid);
			box-shadow: 8px 8px 0 rgba(255, 230, 0, 0.10);
		}

		.deck {
			position: relative;
			z-index: 2;
			max-width: 1100px;
			margin: 0 auto;
			padding: 18px 16px 0;
		}

		.deckGrid {
			display: grid;
			gap: 14px;
			grid-template-columns: 1fr;
		}

		@media (min-width: 900px) {
			.moi-top { grid-template-columns: 1.2fr 0.8fr; align-items: end; }
			.deckGrid { grid-template-columns: 1.2fr 0.8fr; }
		}

		.cassette {
			border: 3px solid var(--fg);
			background: rgba(0, 0, 0, 0.62);
			box-shadow: 14px 14px 0 rgba(0, 0, 0, 0.60);
			padding: 14px;
			position: relative;
		}

		.cassetteShell {
			border: 2px solid rgba(246, 246, 246, 0.35);
			background:
				linear-gradient(180deg, rgba(255, 0, 0, 0.08), transparent 30%),
				linear-gradient(180deg, rgba(246, 246, 246, 0.05), transparent 30%),
				repeating-linear-gradient(90deg, rgba(246, 246, 246, 0.03) 0 1px, transparent 1px 18px);
			padding: 12px;
			position: relative;
		}

		.screws {
			position: absolute;
			inset: 10px;
			pointer-events: none;
			background:
				radial-gradient(circle at 0 0, rgba(246, 246, 246, 0.25) 0 2px, transparent 3px),
				radial-gradient(circle at 100% 0, rgba(246, 246, 246, 0.25) 0 2px, transparent 3px),
				radial-gradient(circle at 0 100%, rgba(246, 246, 246, 0.25) 0 2px, transparent 3px),
				radial-gradient(circle at 100% 100%, rgba(246, 246, 246, 0.25) 0 2px, transparent 3px);
			opacity: 0.8;
		}

		.window {
			position: relative;
			margin-top: 8px;
			height: 170px;
			border: 2px solid rgba(246, 246, 246, 0.30);
			background: rgba(0, 0, 0, 0.55);
			overflow: hidden;
		}

		.tape {
			position: absolute;
			left: 0;
			right: 0;
			top: 50%;
			height: 10px;
			transform: translateY(-50%);
			background: linear-gradient(90deg, rgba(255, 0, 0, 0.20), rgba(246, 246, 246, 0.08), rgba(255, 0, 0, 0.18));
			opacity: 0.9;
		}

		.reel {
			position: absolute;
			top: 50%;
			width: 120px;
			height: 120px;
			border-radius: 999px;
			transform: translateY(-50%);
			background:
				radial-gradient(circle at 50% 50%, rgba(246, 246, 246, 0.22) 0 2px, transparent 3px),
				repeating-conic-gradient(from 0deg, rgba(246, 246, 246, 0.12) 0 10deg, rgba(0, 0, 0, 0) 10deg 26deg);
			border: 2px solid rgba(246, 246, 246, 0.25);
			filter: drop-shadow(0 0 12px rgba(255, 0, 0, 0.10));
		}

		.reel .hub {
			position: absolute;
			inset: 34px;
			border-radius: 999px;
			border: 2px solid rgba(246, 246, 246, 0.30);
			background: rgba(0, 0, 0, 0.55);
		}

		.reelL { left: 18px; }
		.reelR { right: 18px; }

		.is-playing .reel {
			animation: spin calc(2.2s - (var(--spd) * 1.3s)) linear infinite;
		}

		.is-playing .tape {
			animation: tapeMove calc(1.6s - (var(--spd) * 1.0s)) linear infinite;
		}

		@keyframes spin {
			to { transform: translateY(-50%) rotate(360deg); }
		}

		@keyframes tapeMove {
			0% { filter: hue-rotate(0deg); }
			100% { filter: hue-rotate(22deg); }
		}

		.label {
			margin-top: 10px;
			padding: 12px;
			border: 2px solid rgba(246, 246, 246, 0.25);
			background: rgba(0, 0, 0, 0.42);
		}

		.labelRow {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
			gap: 12px;
		}

		.labelTitle {
			font-weight: 900;
			letter-spacing: 0.35em;
			text-transform: uppercase;
			font-size: 11px;
			color: rgba(246, 246, 246, 0.80);
		}

		.labelCode {
			font-weight: 900;
			letter-spacing: 0.22em;
			text-transform: uppercase;
			font-size: 10px;
			color: rgba(246, 246, 246, 0.55);
		}

		.labelText {
			margin-top: 10px;
			font-family: 'Patrick Hand', ui-rounded, system-ui, sans-serif;
			font-size: 26px;
			line-height: 1.12;
		}

		.sep { margin: 0 10px; color: var(--red); }

		.labelMeta {
			margin-top: 10px;
			display: flex;
			flex-wrap: wrap;
			gap: 8px;
		}

		.pill {
			font-weight: 900;
			letter-spacing: 0.22em;
			text-transform: uppercase;
			font-size: 10px;
			padding: 8px 10px;
			border: 2px solid var(--fg);
			background: rgba(0, 0, 0, 0.35);
		}

		.tracklist {
			margin-top: 14px;
			border: 2px solid rgba(246, 246, 246, 0.25);
			background: rgba(0, 0, 0, 0.40);
			padding: 12px;
		}

		.trackHeader {
			display: flex;
			justify-content: space-between;
			align-items: center;
			gap: 12px;
		}

		.trackHeader .k {
			font-weight: 900;
			letter-spacing: 0.35em;
			text-transform: uppercase;
			font-size: 10px;
			color: rgba(246, 246, 246, 0.62);
		}

		.led {
			width: 10px;
			height: 10px;
			border-radius: 999px;
			background: rgba(246, 246, 246, 0.15);
			border: 1px solid rgba(246, 246, 246, 0.25);
		}

		.led.on {
			background: rgba(255, 0, 0, 0.85);
			box-shadow: 0 0 16px rgba(255, 0, 0, 0.35);
		}

		.tracks { margin: 10px 0 0; padding: 0; list-style: none; display: grid; gap: 8px; }

		.track {
			display: grid;
			grid-template-columns: 34px 1fr;
			gap: 10px;
			text-decoration: none;
			padding: 10px 10px;
			border: 2px solid rgba(246, 246, 246, 0.25);
			background: rgba(0, 0, 0, 0.55);
			box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.55);
		}

		.track:hover {
			border-color: rgba(255, 230, 0, 0.55);
			background: rgba(0, 0, 0, 0.85);
		}

		.track:focus-visible {
			outline: 2px solid rgba(255, 230, 0, 0.65);
			outline-offset: 4px;
		}

		.trkId {
			font-weight: 900;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			color: rgba(246, 246, 246, 0.75);
		}

		.trkName {
			font-weight: 900;
			letter-spacing: 0.22em;
			text-transform: uppercase;
			font-size: 12px;
			display: block;
		}

		.trkNote {
			grid-column: 2;
			font-size: 12px;
			color: rgba(246, 246, 246, 0.62);
			letter-spacing: 0.08em;
		}

		.controls {
			margin-top: 14px;
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 8px;
			align-items: end;
		}

		.btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 10px 10px;
			border: 2px solid var(--fg);
			background: rgba(0, 0, 0, 0.55);
			box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.55);
			font-weight: 900;
			letter-spacing: 0.22em;
			text-transform: uppercase;
			font-size: 11px;
			text-decoration: none;
		}

		.btn:hover { background: rgba(0, 0, 0, 0.85); }
		.btn:focus-visible { outline: 2px solid rgba(255, 230, 0, 0.65); outline-offset: 4px; }
		.btnPlay { border-color: rgba(255, 230, 0, 0.65); }
		.btnRec { border-color: rgba(255, 0, 0, 0.75); }
		.btnEject { border-style: dashed; }

		.knob {
			grid-column: 1 / -1;
			display: grid;
			gap: 6px;
			margin-top: 8px;
			padding: 10px 10px;
			border: 2px solid rgba(246, 246, 246, 0.25);
			background: rgba(0, 0, 0, 0.40);
		}

		.knobLabel {
			font-weight: 900;
			letter-spacing: 0.35em;
			text-transform: uppercase;
			font-size: 10px;
			color: rgba(246, 246, 246, 0.62);
		}

		.knob input { width: 100%; }

		.help {
			grid-column: 1 / -1;
			font-size: 10px;
			letter-spacing: 0.18em;
			text-transform: uppercase;
			color: rgba(246, 246, 246, 0.58);
		}

		.notes {
			border: 3px solid var(--fg);
			background: rgba(0, 0, 0, 0.50);
			box-shadow: 14px 14px 0 rgba(255, 0, 0, 0.10);
			padding: 14px;
			position: relative;
			transform: rotate(-0.6deg);
		}

		.notesTop {
			display: flex;
			justify-content: space-between;
			align-items: baseline;
			gap: 12px;
		}

		.stamp {
			background: rgba(255, 0, 0, 0.82);
			color: #000;
			border: 2px solid #000;
			font-weight: 900;
			letter-spacing: 0.28em;
			text-transform: uppercase;
			font-size: 11px;
