        0 0 14px color-mix(in oklab, var(--c) 60%, transparent),
        10px 10px 0 rgba(0,0,0,0.55);

      color: rgba(246,246,246,0.92);
      cursor: pointer;
      user-select: none;
      outline: none;
      transition: transform 200ms ease, box-shadow 200ms ease, opacity 200ms ease, filter 200ms ease;
    }

    .nn-node::before,
    .nn-node::after {
      content: '';
      position: absolute;
      inset: 6px;
      border-radius: inherit;
      pointer-events: none;
      opacity: 0;
    }

    /* Variants: more diversity than just color */
    .nn-node[data-variant='dashed'] { border-style: dashed; border-width: 2px; }
    .nn-node[data-variant='dashed']::before {
      opacity: 0.55;
      border: 1px dashed rgba(246,246,246,0.35);
