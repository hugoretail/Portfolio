    .nn-node[data-variant='chip'] {
      --shape: 18px;
      border-width: 2px;
      box-shadow:
        0 0 0 2px rgba(0,0,0,0.55) inset,
        0 0 12px color-mix(in oklab, var(--c) 45%, transparent),
        12px 12px 0 rgba(0,0,0,0.58);
    }
    .nn-node[data-variant='chip']::before {
      opacity: 0.55;
      background:
        linear-gradient(90deg, rgba(246,246,246,0.18), transparent 45%),
        repeating-linear-gradient(0deg, rgba(255,255,255,0.06) 0 1px, transparent 1px 6px);
      mix-blend-mode: screen;
    }

    .nn-node[data-variant='scan']::before {
      opacity: 0.55;
      background:
        repeating-linear-gradient(0deg, rgba(0,255,255,0.14) 0 1px, transparent 1px 5px),
        radial-gradient(circle at 20% 20%, rgba(255,0,0,0.10), transparent 45%);
      mix-blend-mode: screen;
    }

    .nn-node.is-on::before,
    .nn-node:hover::before {
      opacity: 0.60;
    }

    /* During intro animation: no hover flare */
    .nn-stage__inner.is-intro .nn-node:hover::before { opacity: 0; }
    .nn-stage__inner.is-intro .nn-node:hover {
      transform: translate(-50%, -50%) scale(1);
      box-shadow:
        0 0 0 2px rgba(0,0,0,0.55) inset,
