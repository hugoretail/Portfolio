<BaseLayout title="Hugo — Informatique" description="Réseau de neurones (brutaliste) pour explorer mes compétences.">
  <div id="nnPage" class="nn-page relative min-h-screen overflow-hidden">
    <div class="pointer-events-none absolute inset-0 bg-black" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 nn-grid" aria-hidden="true"></div>
    <div class="paper-grain" aria-hidden="true"></div>
    <div class="noise-overlay" aria-hidden="true"></div>

    <a class="bb-backbtn brutal-border" href="/moi" aria-label="Retour à /moi" title="Retour">
      <span aria-hidden="true">←</span>
    </a>

    <main class="relative z-10 mx-auto max-w-7xl px-4 pb-16 pt-8">
      <header class="mb-8">
        <div class="font-black uppercase tracking-widest text-xs text-[color:var(--muted)]">informatique</div>
        <h1 class="mt-2 font-display text-6xl leading-none md:text-7xl">RÉSEAU DE NEURONES</h1>
        <p class="mt-3 max-w-3xl font-hand text-2xl text-[color:var(--muted)]">
          Survole: info-bulle. Clique: modale. Lancement: le réseau se dessine en &lt; 5s.
        </p>
      </header>

      <section class="nn-stage brutal-border" aria-label="Réseau de neurones interactif">
        <div id="nnStage" class="nn-stage__inner" role="application" aria-label="Réseau de compétences">
          <svg id="nnSvg" class="nn-svg" aria-hidden="true"></svg>

          <div class="nn-nodes">
            {nodes.map((n) => (
              <button
                type="button"
                class:list={[
                  'nn-node',
                  n.kind === 'center' && 'nn-node--center',
                  n.kind === 'main' && 'nn-node--main',
                  n.kind === 'sub' && 'nn-node--sub'
                ]}
                style={`--x:${n.x}%; --y:${n.y}%; --c:${n.color};`}
                data-id={n.id}
                data-parent={n.parent ?? ''}
                data-variant={n.variant ?? 'ring'}
                data-label={n.label}
                data-tip={n.tip}
                data-detail-title={n.detailTitle}
                data-detail={n.detail}
                data-tags={(n.tags ?? []).join(',')}
                data-bullets={(n.bullets ?? []).join('|||')}
                data-href={n.href ?? ''}
                aria-label={`${n.detailTitle}: ${n.tip}`}
              >
                <span class="nn-node__txt">{n.label}</span>
              </button>
            ))}
          </div>

          <div id="nnTip" class="nn-tip" role="tooltip" hidden>
            <div class="nn-tip__title" id="nnTipTitle"></div>
            <div class="nn-tip__sub" id="nnTipSub"></div>
          </div>
        </div>
      </section>
    </main>

    <dialog id="nnModal" class="nn-modal">
      <form method="dialog" class="nn-modal__backdrop">
        <button id="nnMX" aria-label="Fermer" class="nn-modal__x" type="button">✕</button>
        <div class="nn-modal__panel brutal-border" role="document">
          <div class="nn-modal__head">
            <div>
              <div class="nn-modal__kicker">OUVRIR</div>
              <div id="nnMT" class="nn-modal__title"></div>
              <div id="nnMD" class="nn-modal__desc"></div>
            </div>
            <a id="nnML" class="nn-modal__link" target="_blank" rel="noreferrer">Lien ↗</a>
          </div>
          <ul id="nnMB" class="nn-modal__bullets"></ul>

          <div class="nn-projs" aria-label="Projets liés">
            <div class="nn-projs__kicker">PROJETS LIÉS</div>
            <div class="nn-projs__grid">
              <div class="nn-projs__list" id="nnPL" role="list"></div>
              <div class="nn-projs__detail" id="nnPD">
                <div class="nn-projs__empty">Clique un projet à gauche.</div>
              </div>
            </div>
          </div>

          <div class="nn-modal__foot">
            <div class="nn-modal__hint">Esc pour fermer</div>
            <button class="tool" value="close" type="submit">Fermer</button>
          </div>
        </div>
      </form>
    </dialog>

    <script
      type="application/json"
      id="nnProjectsData"
      set:html={JSON.stringify(projects).replace(/</g, '\\u003c')}
    ></script>
  </div>

  <script is:inline>
    (() => {
      const page = document.getElementById('nnPage');
      const stage = document.getElementById('nnStage');
      const svg = document.getElementById('nnSvg');
      const modal = document.getElementById('nnModal');
      const mT = document.getElementById('nnMT');
      const mD = document.getElementById('nnMD');
      const mB = document.getElementById('nnMB');
      const mL = document.getElementById('nnML');
      const pData = document.getElementById('nnProjectsData');
      const pList = document.getElementById('nnPL');
      const pDetail = document.getElementById('nnPD');
      const tip = document.getElementById('nnTip');
      const tipTitle = document.getElementById('nnTipTitle');
      const tipSub = document.getElementById('nnTipSub');

      if (!page || !stage || !svg || !tip || !tipTitle || !tipSub) return;

      let introDone = false;

      /** @type {Array<any>} */
      let projects = [];
      try {
        projects = JSON.parse((pData && pData.textContent) ? pData.textContent : '[]');
        if (!Array.isArray(projects)) projects = [];
      } catch {
        projects = [];
      }

      const uniq = (arr) => Array.from(new Set((arr || []).filter(Boolean)));
      const normTag = (x) => String(x ?? '').trim().toLowerCase();
      const tagsOf = (p) => {
        const t = Array.isArray(p?.tags) ? p.tags : [];
        const l = Array.isArray(p?.labels) ? p.labels : [];
        return uniq([...t, ...l].map(normTag)).filter(Boolean);
      };
      const intersectCount = (a, b) => {
        const setB = new Set(b);
        let c = 0;
        a.forEach((x) => { if (setB.has(x)) c += 1; });
        return c;
      };

      const yearToInt = (y) => {
        const n = parseInt(String(y || '').trim(), 10);
        return Number.isFinite(n) ? n : 0;
      };

      const renderProjectDetail = (p) => {
        if (!pDetail) return;
        pDetail.replaceChildren();

        const head = document.createElement('div');
        head.className = 'nn-proj';

        {
          const placeholderSrc = '/assets/images/informatique/project-placeholder.svg';
          const media = document.createElement('div');
          media.className = 'nn-proj__media brutal-border';

          const img = document.createElement('img');
          img.loading = 'lazy';
          img.decoding = 'async';
          img.alt = p?.title ? String(p.title) : 'Image projet';
          img.src = p?.image ? String(p.image) : placeholderSrc;
          img.addEventListener('error', () => {
            if (img.getAttribute('data-fallback') === '1') return;
            img.setAttribute('data-fallback', '1');
            img.src = placeholderSrc;
          });
          media.appendChild(img);

          head.appendChild(media);
        }

        const title = document.createElement('div');
        title.className = 'nn-proj__title';
        title.textContent = p?.title || 'Projet';
        head.appendChild(title);

        const meta = document.createElement('div');
        meta.className = 'nn-proj__meta';
        const bits = [];
        if (p?.year) bits.push(String(p.year));
        if (p?.duration) bits.push(String(p.duration));
        meta.textContent = bits.join(' · ') || '—';
        head.appendChild(meta);

        if (p?.description) {
          const desc = document.createElement('div');
          desc.className = 'nn-proj__desc';
          desc.textContent = String(p.description);
          head.appendChild(desc);
        }

        if (Array.isArray(p?.tools) && p.tools.length) {
          const tools = document.createElement('div');
          tools.className = 'nn-proj__chips';
          p.tools.slice(0, 14).forEach((t) => {
            const chip = document.createElement('span');
            chip.className = 'nn-chip';
            chip.textContent = String(t);
            tools.appendChild(chip);
          });
          head.appendChild(tools);
        }

        const mkList = (kicker, items) => {
          if (!Array.isArray(items) || !items.length) return;
          const box = document.createElement('div');
          box.className = 'nn-proj__box';
          const k = document.createElement('div');
          k.className = 'nn-proj__k';
          k.textContent = kicker;
          box.appendChild(k);
          const ul = document.createElement('ul');
          ul.className = 'nn-proj__ul';
          items.slice(0, 10).forEach((x) => {
            const li = document.createElement('li');
            li.textContent = String(x);
            ul.appendChild(li);
          });
          box.appendChild(ul);
          head.appendChild(box);
        };

        mkList('COMPÉTENCES', p?.competences);
        mkList('CAHIER DES CHARGES', p?.cdc);
        mkList('À GARDER', p?.keep);
        mkList('À AMÉLIORER', p?.improve);

        if (p?.href) {
          const a = document.createElement('a');
          a.className = 'nn-proj__link';
          a.target = '_blank';
          a.rel = 'noreferrer';
          a.href = String(p.href);
          a.textContent = 'Ouvrir ↗';
          head.appendChild(a);
        }

        pDetail.appendChild(head);
      };

      const renderProjectsForTags = (nodeTags) => {
        if (!pList || !pDetail) return;
        pList.replaceChildren();
        pDetail.replaceChildren();
        {
          const empty = document.createElement('div');
          empty.className = 'nn-projs__empty';
          empty.textContent = 'Clique un projet à gauche.';
          pDetail.appendChild(empty);
        }

        const tags = Array.isArray(nodeTags) ? uniq(nodeTags.map(normTag)).filter(Boolean) : [];
        if (!tags.length) {
          const empty = document.createElement('div');
          empty.className = 'nn-projs__note';
          empty.textContent = 'Ce nœud est un hub. Choisis un thème pour afficher des projets.';
          pList.appendChild(empty);
          return;
        }

        const scored = projects
          .map((p) => ({ p, s: intersectCount(tagsOf(p), tags) }))
          .filter((x) => x.s > 0)
          .sort((a, b) => (b.s - a.s) || (yearToInt(b.p?.year) - yearToInt(a.p?.year)) || String(a.p?.title || '').localeCompare(String(b.p?.title || '')));

        if (!scored.length) {
          const empty = document.createElement('div');
          empty.className = 'nn-projs__note';
          empty.textContent = 'Aucun projet trouvé pour ce thème.';
          pList.appendChild(empty);
          return;
        }

        const makeBtn = (item) => {
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'nn-projrow';
          btn.setAttribute('role', 'listitem');

          const t = document.createElement('div');
          t.className = 'nn-projrow__t';
          t.textContent = item.p?.title || 'Projet';
          btn.appendChild(t);

          const m = document.createElement('div');
          m.className = 'nn-projrow__m';
          const y = item.p?.year ? String(item.p.year) : '';
          const dur = item.p?.duration ? String(item.p.duration) : '';
          const hint = tagsOf(item.p).slice(0, 3).join(' / ');
          m.textContent = [y, dur, hint].filter(Boolean).join(' · ') || '—';
          btn.appendChild(m);

          btn.addEventListener('click', () => {
            pList.querySelectorAll('.nn-projrow').forEach((x) => x.classList.remove('is-active'));
            btn.classList.add('is-active');
            renderProjectDetail(item.p);
          });

          return btn;
        };

        scored.slice(0, 20).forEach((item, idx) => {
          const btn = makeBtn(item);
          pList.appendChild(btn);
          if (idx === 0) {
            btn.classList.add('is-active');
            renderProjectDetail(item.p);
          }
        });
      };

      const prefersReducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches ?? false;

      const nodes = Array.from(stage.querySelectorAll('.nn-node'));
      const byId = new Map(nodes.map((el) => [el.getAttribute('data-id'), el]));
      const edges = nodes
        .map((el) => [el.getAttribute('data-parent') || '', el.getAttribute('data-id') || ''])
        .filter(([p, id]) => p && id);

      const setModalOpen = (on) => {
        document.documentElement.classList.toggle('is-modal-open', !!on);
        document.body.classList.toggle('is-modal-open', !!on);
      };

      let lastModalFrom = null;
      let isClosingModal = false;

      const fitAllLabels = () => {
        const els = Array.from(stage.querySelectorAll('.nn-node'));
        els.forEach((btn) => {
          const txt = btn.querySelector('.nn-node__txt');
          if (!txt) return;

          // Reset so measurements are stable
          btn.style.removeProperty('--fs');
          btn.style.removeProperty('--ls');

          const label = (btn.getAttribute('data-label') || '').trim();
          if (label.length >= 8) btn.style.setProperty('--ls', '0.14em');
          if (label.length >= 10) btn.style.setProperty('--ls', '0.10em');

          // If still overflowing, step font-size down a bit.
          const maxSteps = 16;
          let fs = parseFloat(getComputedStyle(txt).fontSize || '10');
          const minFs = 8;
          let steps = 0;
          while (steps < maxSteps && fs > minFs) {
            // scrollWidth/Height are stable even with grid centering
            if (txt.scrollWidth <= txt.clientWidth + 1 && txt.scrollHeight <= txt.clientHeight + 1) break;
            fs = Math.max(minFs, fs - 0.5);
            btn.style.setProperty('--fs', `${fs}px`);
            steps += 1;
          }
        });
      };

      const prepModalAnimationFrom = (fromEl) => {
        if (!modal) return;
        const r = fromEl.getBoundingClientRect();
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        const cx = r.left + r.width / 2;
        const cy = r.top + r.height / 2;
        const dx = cx - vw / 2;
        const dy = cy - vh / 2;
        const targetW = Math.min(1040, vw * 0.94);
        const s = clamp(r.width / Math.max(1, targetW), 0.06, 0.92);

        lastModalFrom = { el: fromEl, dx, dy, s };

        modal.style.setProperty('--from-dx', `${dx}px`);
        modal.style.setProperty('--from-dy', `${dy}px`);
        modal.style.setProperty('--from-s', `${s}`);
        modal.classList.add('nn-modal--anim');
        modal.classList.remove('nn-modal--open');

        fromEl.classList.add('is-opening');
        window.setTimeout(() => fromEl.classList.remove('is-opening'), 260);
      };

      const closeModalAnimated = (reason) => {
        if (!modal) return;
        if (isClosingModal) return;
        if (!modal.hasAttribute('open')) return;

        if (prefersReducedMotion || !modal.classList.contains('nn-modal--anim')) {
          try {
            modal.close();
          } catch {
            modal.removeAttribute('open');
          }
          return;
        }

        isClosingModal = true;

        const panel = modal.querySelector('.nn-modal__panel');
        const backdrop = modal.querySelector('.nn-modal__backdrop');

        const dx = lastModalFrom?.dx ?? 0;
        const dy = lastModalFrom?.dy ?? 0;
        const s = lastModalFrom?.s ?? 0.1;

        if (lastModalFrom?.el) {
          lastModalFrom.el.classList.add('is-opening');
          window.setTimeout(() => lastModalFrom?.el?.classList?.remove?.('is-opening'), 260);
        }

        /** @type {Animation | null} */
        let pAnim = null;
        /** @type {Animation | null} */
        let bAnim = null;

        try {
          if (panel && typeof panel.animate === 'function') {
            panel.getAnimations?.().forEach((a) => a.cancel());
            pAnim = panel.animate(
              [
                { transform: 'translate(0px, 0px) scale(1)', borderRadius: '14px', opacity: 1, filter: 'none' },
                { transform: `translate(${dx}px, ${dy}px) scale(${s})`, borderRadius: '999px', opacity: 0.10, filter: 'blur(0.5px) saturate(1.08)' }
              ],
              { duration: 420, easing: 'cubic-bezier(.17,.84,.28,1)', fill: 'forwards' }
            );
          }

          if (backdrop && typeof backdrop.animate === 'function') {
            backdrop.getAnimations?.().forEach((a) => a.cancel());
            bAnim = backdrop.animate(
              [{ opacity: 1 }, { opacity: 0 }],
              { duration: 260, easing: 'ease', fill: 'forwards' }
            );
          }
        } catch {
          // ignore
        }

        const done = () => {
          isClosingModal = false;
          try {
            modal.close();
          } catch {
            modal.removeAttribute('open');
          }
        };

        const waits = [];
        if (pAnim?.finished) waits.push(pAnim.finished.catch(() => {}));
        if (bAnim?.finished) waits.push(bAnim.finished.catch(() => {}));

        if (waits.length) Promise.all(waits).then(done);
        else window.setTimeout(done, 420);
      };

      const openModal = (el) => {
        if (!modal || !mT || !mD || !mB || !mL) return;

        // If the modal was previously closed with WAAPI, ensure no finished animations keep it invisible.
        {
          const panel = modal.querySelector('.nn-modal__panel');
          const backdrop = modal.querySelector('.nn-modal__backdrop');
          panel?.getAnimations?.().forEach((a) => a.cancel());
          backdrop?.getAnimations?.().forEach((a) => a.cancel());
          (panel instanceof HTMLElement) && panel.style.removeProperty('opacity');
          (panel instanceof HTMLElement) && panel.style.removeProperty('transform');
          (panel instanceof HTMLElement) && panel.style.removeProperty('filter');
          (panel instanceof HTMLElement) && panel.style.removeProperty('border-radius');
          (backdrop instanceof HTMLElement) && backdrop.style.removeProperty('opacity');
        }

        const title = el.getAttribute('data-detail-title') || el.getAttribute('data-label') || 'Détail';
        const detail = el.getAttribute('data-detail') || '';
        const bulletsRaw = el.getAttribute('data-bullets') || '';
        const href = el.getAttribute('data-href') || '';
        const tagsRaw = el.getAttribute('data-tags') || '';
        const nodeTags = tagsRaw.split(',').map((s) => s.trim()).filter(Boolean);

        // Accent = node color (fix: title readability)
        {
          const c = (getComputedStyle(el).getPropertyValue('--c') || '').trim();
          if (c) modal.style.setProperty('--accent', c);
        }

        mT.textContent = title;
        mD.textContent = detail;
        mB.replaceChildren();
        const bullets = bulletsRaw ? bulletsRaw.split('|||').filter(Boolean) : [];
        bullets.forEach((b) => {
          const li = document.createElement('li');
          li.textContent = b;
          mB.appendChild(li);
        });

        if (href) {
          mL.setAttribute('href', href);
          mL.style.display = '';
        } else {
          mL.removeAttribute('href');
          mL.style.display = 'none';
        }

        renderProjectsForTags(nodeTags);

        prepModalAnimationFrom(el);

        try {
          if (typeof modal.showModal === 'function') modal.showModal();
          else modal.setAttribute('open', 'true');
        } catch {
          modal.setAttribute('open', 'true');
        }
        setModalOpen(true);

        if (!prefersReducedMotion) {
          requestAnimationFrame(() => {
            // Trigger transition on the panel
            modal.classList.add('nn-modal--open');
          });
        } else {
          modal.classList.add('nn-modal--open');
        }
      };

      if (modal) {
        const clear = () => {
          isClosingModal = false;

          // Important: cancel any WAAPI animations (they can persist with fill:forwards and keep opacity 0)
          const panel = modal.querySelector('.nn-modal__panel');
          const backdrop = modal.querySelector('.nn-modal__backdrop');
          panel?.getAnimations?.().forEach((a) => a.cancel());
          backdrop?.getAnimations?.().forEach((a) => a.cancel());
          (panel instanceof HTMLElement) && panel.style.removeProperty('opacity');
          (panel instanceof HTMLElement) && panel.style.removeProperty('transform');
          (panel instanceof HTMLElement) && panel.style.removeProperty('filter');
          (panel instanceof HTMLElement) && panel.style.removeProperty('border-radius');
          (backdrop instanceof HTMLElement) && backdrop.style.removeProperty('opacity');

          setModalOpen(false);
          modal.classList.remove('nn-modal--open');
          modal.classList.remove('nn-modal--anim');
          modal.style.removeProperty('--from-dx');
          modal.style.removeProperty('--from-dy');
          modal.style.removeProperty('--from-s');
          modal.style.removeProperty('--accent');
        };
        modal.addEventListener('close', clear);

        // Esc closes with reverse animation
        modal.addEventListener('cancel', (e) => {
          e.preventDefault();
          closeModalAnimated('esc');
        });

        // Click outside panel closes the modal
        modal.addEventListener('click', (e) => {
          const panel = modal.querySelector('.nn-modal__panel');
          const target = e.target;
          if (panel && target instanceof Node && !panel.contains(target)) {
            e.preventDefault();
            closeModalAnimated('outside');
          }
        });

        // Close button
        const xBtn = document.getElementById('nnMX');
        if (xBtn) {
          xBtn.addEventListener('click', (e) => {
            e.preventDefault();
            closeModalAnimated('x');
          });
        }
      }

      // Build SVG links
      const NS = 'http://www.w3.org/2000/svg';
      const paths = [];
      const adjacency = new Map();
      const addAdj = (a, b) => {
        if (!adjacency.has(a)) adjacency.set(a, new Set());
        adjacency.get(a).add(b);
      };

      edges.forEach(([from, to]) => {
        const p = document.createElementNS(NS, 'path');
        p.classList.add('nn-link');
        p.setAttribute('data-from', from);
        p.setAttribute('data-to', to);

        const toEl = byId.get(to);
        const rawColor = (toEl?.style?.getPropertyValue('--c') || '').trim();
        const color = rawColor || (toEl ? (getComputedStyle(toEl).getPropertyValue('--c') || '').trim() : '');
        if (color) p.style.setProperty('--lc', color);

        svg.appendChild(p);
        paths.push(p);
        addAdj(from, to);
        addAdj(to, from);
      });

      const clamp = (n, a, b) => Math.max(a, Math.min(b, n));

      const curvePath = (ax, ay, bx, by) => {
        const dx = bx - ax;
        const dy = by - ay;
        const dist = Math.max(1, Math.hypot(dx, dy));
        const nx = -dy / dist;
        const ny = dx / dist;
        const bend = clamp(dist * 0.18, 18, 90);
        const c1x = ax + dx * 0.25 + nx * bend;
        const c1y = ay + dy * 0.25 + ny * bend;
        const c2x = ax + dx * 0.75 + nx * bend;
        const c2y = ay + dy * 0.75 + ny * bend;
        return `M ${ax.toFixed(2)} ${ay.toFixed(2)} C ${c1x.toFixed(2)} ${c1y.toFixed(2)}, ${c2x.toFixed(2)} ${c2y.toFixed(2)}, ${bx.toFixed(2)} ${by.toFixed(2)}`;
      };

      const layout = () => {
        const r = stage.getBoundingClientRect();
        const w = Math.max(1, r.width);
        const h = Math.max(1, r.height);
        svg.setAttribute('viewBox', `0 0 ${w} ${h}`);
        svg.setAttribute('width', String(w));
        svg.setAttribute('height', String(h));

        const centerOf = (el) => {
          const b = el.getBoundingClientRect();
          return { x: (b.left - r.left) + b.width / 2, y: (b.top - r.top) + b.height / 2 };
        };

        paths.forEach((p) => {
          const from = p.getAttribute('data-from');
          const to = p.getAttribute('data-to');
          const aEl = byId.get(from);
          const bEl = byId.get(to);
          if (!aEl || !bEl) return;
          const a = centerOf(aEl);
          const b = centerOf(bEl);
          p.setAttribute('d', curvePath(a.x, a.y, b.x, b.y));

          try {
            const len = p.getTotalLength();
            p.style.strokeDasharray = `${len}`;
            p.style.strokeDashoffset = `${len}`;
          } catch {
            // ignore
          }
        });
      };

      const debounce = (fn, ms) => {
        let t = 0;
        return () => {
          window.clearTimeout(t);
          t = window.setTimeout(fn, ms);
        };
      };

      const relayout = debounce(layout, 60);
      window.addEventListener('resize', relayout, { passive: true });
      window.addEventListener('resize', debounce(fitAllLabels, 90), { passive: true });

      // Tooltip
      const showTip = (el, e) => {
        tipTitle.textContent = el.getAttribute('data-label') || '—';
        tipSub.textContent = el.getAttribute('data-tip') || '';
        tip.hidden = false;
        moveTip(e);
      };

      const moveTip = (e) => {
        if (tip.hidden) return;
        const pad = 12;
        const tw = tip.offsetWidth || 240;
        const th = tip.offsetHeight || 72;
        const vw = window.innerWidth;
        const vh = window.innerHeight;
        let x = e.clientX + 14;
        let y = e.clientY + 14;
        if (x + tw + pad > vw) x = e.clientX - tw - 14;
        if (y + th + pad > vh) y = e.clientY - th - 14;
        x = clamp(x, pad, vw - tw - pad);
        y = clamp(y, pad, vh - th - pad);
        tip.style.transform = `translate(${x}px, ${y}px)`;
      };

      const hideTip = () => {
        tip.hidden = true;
      };

      const clearHot = () => {
        stage.classList.remove('has-hot');
        nodes.forEach((n) => n.classList.remove('is-dim', 'is-hot'));
        paths.forEach((p) => p.classList.remove('is-hot', 'is-dim'));
      };

      const setHot = (id) => {
        clearHot();
        stage.classList.add('has-hot');
        nodes.forEach((n) => n.classList.add('is-dim'));
        paths.forEach((p) => p.classList.add('is-dim'));

        const neighbors = adjacency.get(id);
        const hotIds = neighbors ? new Set([id, ...neighbors]) : new Set([id]);

        nodes.forEach((n) => {
          const nid = n.getAttribute('data-id');
          if (hotIds.has(nid)) n.classList.remove('is-dim');
          if (nid === id) n.classList.add('is-hot');
        });

        paths.forEach((p) => {
          const a = p.getAttribute('data-from');
          const b = p.getAttribute('data-to');
          if (hotIds.has(a) && hotIds.has(b)) p.classList.add('is-hot');
          else p.classList.remove('is-hot');
        });
      };

      nodes.forEach((el) => {
        el.addEventListener('pointerenter', (e) => {
          if (!introDone) return;
          showTip(el, e);
          const id = el.getAttribute('data-id');
          if (id) setHot(id);
        });
        el.addEventListener('pointermove', (e) => {
          if (!introDone) return;
          moveTip(e);
        }, { passive: true });
        el.addEventListener('pointerleave', () => {
          if (!introDone) return;
          hideTip();
          clearHot();
        });
        el.addEventListener('click', () => openModal(el));
      });

      // Init animation (<5s)
      const appearOrder = ['hugo','ia','web','data','devops','sec','sys','net','3d','dl','nlp','tests','arch'];

      const DRAW_MS = prefersReducedMotion ? 0 : 1200;
      const NODE_DELAY_MS = prefersReducedMotion ? 0 : 420;

      const showNode = (id) => {
        const el = byId.get(id);
        if (!el) return;

        // Draw the incoming link first, then "energize" the node.
        paths.forEach((p) => {
          if (p.getAttribute('data-to') !== id) return;
          p.style.setProperty('--draw', `${DRAW_MS}ms`);
          p.classList.add('is-on');
        });

        if (id === 'hugo' || prefersReducedMotion) {
          el.classList.add('is-on');
          return;
        }

        window.setTimeout(() => el.classList.add('is-on'), NODE_DELAY_MS);
      };

      requestAnimationFrame(() => {
        layout();
        fitAllLabels();
        if (prefersReducedMotion) {
          appearOrder.forEach(showNode);
          paths.forEach((p) => p.classList.add('is-on'));
          introDone = true;
          stage.classList.remove('is-intro');
          return;
        }

        showNode('hugo');
        let t = 600;
        appearOrder.slice(1).forEach((id) => {
          window.setTimeout(() => showNode(id), t);
          t += 220;
        });

        introDone = false;
        stage.classList.add('is-intro');
        const total = 600 + Math.max(0, (appearOrder.length - 2) * 220) + Math.max(DRAW_MS, NODE_DELAY_MS) + 260;
        window.setTimeout(() => {
          introDone = true;
          stage.classList.remove('is-intro');
        }, total);
      });
    })();
  </script>

  <style is:global>
    .nn-page {
      --bg: #070708;
      --fg: rgba(246,246,246,0.90);
      --muted: rgba(246,246,246,0.62);
      --red: #ff0000;
      background: var(--bg);
      color: var(--fg);
    }

    html.is-modal-open,
    body.is-modal-open {
      overflow: hidden;
    }

    .bb-backbtn {
      position: fixed;
      top: 18px;
      left: 18px;
      z-index: 60;
      display: inline-grid;
      place-items: center;
      width: 44px;
      height: 44px;
      background: rgba(0,0,0,0.60);
      border: 2px solid rgba(246,246,246,0.45);
      color: rgba(246,246,246,0.88);
      font-weight: 900;
      font-size: 18px;
      line-height: 1;
      text-decoration: none;
      box-shadow: 8px 8px 0 rgba(0,0,0,0.60);
      transition: background 140ms ease, transform 140ms ease;
    }

    .bb-backbtn:hover {
      background: rgba(0,0,0,0.72);
      transform: translateY(-1px);
    }

    .nn-grid {
      background:
        radial-gradient(1000px 700px at 18% 20%, rgba(157,0,255,0.10), transparent 60%),
        radial-gradient(900px 650px at 78% 70%, rgba(0,255,255,0.10), transparent 62%),
        radial-gradient(900px 700px at 52% 95%, rgba(255,0,0,0.10), transparent 65%),
        repeating-linear-gradient(0deg, rgba(255,255,255,0.05) 0 1px, transparent 1px 26px),
        repeating-linear-gradient(90deg, rgba(255,255,255,0.045) 0 1px, transparent 1px 26px);
