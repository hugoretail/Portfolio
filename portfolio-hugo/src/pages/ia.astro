---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Redirection — Informatique" description="Redirection vers /informatique">
  <main class="relative min-h-screen overflow-hidden">
    <div class="absolute inset-0 bg-black" aria-hidden="true"></div>
    <div class="paper-grain" aria-hidden="true"></div>
    <div class="noise-overlay" aria-hidden="true"></div>

    <section class="relative z-10 mx-auto max-w-3xl px-4 py-16">
      <div class="brutal-border bg-black/50 p-5">
        <div class="font-display text-4xl">Redirection…</div>
        <p class="mt-3 font-hand text-2xl text-[color:var(--muted)]">
          La page IA/NLP est devenue <b>Informatique</b>.
        </p>
        <a class="mt-4 inline-block text-sm font-black uppercase tracking-widest underline" href="/informatique">
          Aller sur /informatique
        </a>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      try {
        window.location.replace('/informatique');
      } catch {
        window.location.href = '/informatique';
      }
    })();
  </script>
</BaseLayout>
