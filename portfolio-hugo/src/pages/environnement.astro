---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/withBase';
---

<BaseLayout title="Hugo — Environnement" description="Page en construction.">
  <main class="relative min-h-screen overflow-hidden">
    <div class="absolute inset-0 bg-black" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 bg-nature opacity-[0.06]" aria-hidden="true"></div>
    <div class="paper-grain" aria-hidden="true"></div>
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="river-vignette" aria-hidden="true"></div>

    <a class="bb-backbtn" href={withBase('/moi')} aria-label="Retour à Moi">←</a>

    <div class="relative z-10 px-4 py-14">
      <section class="wip" aria-label="Work In Progress">
        <div class="wip__panel">
          <div class="wip__kicker">Environnement</div>
          <h1 class="wip__title">Work In Progress</h1>
          <p class="wip__desc">Je suis en train de peaufiner cette page. Reviens bientôt.</p>
          <div class="wip__tag">En chantier</div>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  .bb-backbtn {
    position: fixed;
    top: 18px;
    left: 18px;
    z-index: 60;
    display: inline-grid;
    place-items: center;
    width: 44px;
    height: 44px;
    background: rgba(0, 0, 0, 0.6);
    border: 2px solid rgba(246, 246, 246, 0.45);
    color: rgba(246, 246, 246, 0.88);
    font-weight: 900;
    font-size: 18px;
    line-height: 1;
    text-decoration: none;
    box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.6);
    transition: background 140ms ease, transform 140ms ease;
  }

  .bb-backbtn:hover {
    background: rgba(0, 0, 0, 0.72);
    transform: translateY(-1px);
  }

  @media (max-width: 860px) {
    .bb-backbtn {
      top: 12px;
      left: 12px;
      width: 40px;
      height: 40px;
    }
  }

  .river-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 20% 20%, rgba(255, 230, 0, 0.06), transparent 55%),
      radial-gradient(circle at 80% 65%, rgba(255, 0, 0, 0.05), transparent 60%),
      radial-gradient(circle at 50% 50%, rgba(0, 0, 0, 0.10), rgba(0, 0, 0, 0.74));
    opacity: 0.72;
  }

  .wip {
    display: grid;
    place-items: center;
    min-height: calc(100vh - 120px);
  }

  .wip__panel {
    width: min(860px, 92vw);
    border: 2px solid rgba(246, 246, 246, 0.55);
    background: rgba(0, 0, 0, 0.58);
    box-shadow: 12px 12px 0 rgba(0, 0, 0, 0.62);
    padding: 18px 18px 16px;
    clip-path: polygon(1% 4%, 98% 0, 100% 88%, 92% 100%, 2% 96%, 0 18%);
    backdrop-filter: blur(2px);
  }

  .wip__kicker {
    font-size: 10px;
    font-weight: 900;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(246, 246, 246, 0.62);
  }

  .wip__title {
    margin-top: 10px;
    font-weight: 900;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    font-size: clamp(30px, 5vw, 54px);
    color: rgba(246, 246, 246, 0.92);
  }

  .wip__desc {
    margin-top: 12px;
    font-family: var(--font-ui);
    font-size: 22px;
    line-height: 1.12;
    color: rgba(246, 246, 246, 0.86);
    max-width: 62ch;
  }

  .wip__tag {
    margin-top: 14px;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 10px;
    border: 2px solid rgba(255, 230, 0, 0.55);
    color: rgba(255, 230, 0, 0.92);
    font-weight: 900;
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: rgba(0, 0, 0, 0.45);
  }
</style>
