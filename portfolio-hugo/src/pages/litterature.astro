---
import BaseLayout from '../layouts/BaseLayout.astro';

const to = '/environnement';
---

<BaseLayout title="Redirect — Environnement" description="Redirection vers /environnement.">
  <main class="relative min-h-screen overflow-hidden">
    <div class="absolute inset-0 bg-black" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 bg-nature opacity-[0.08]" aria-hidden="true"></div>
    <div class="paper-grain" aria-hidden="true"></div>
    <div class="noise-overlay" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-3xl px-4 py-14">
      <h1 class="font-display text-5xl md:text-6xl">Cette page a bougé.</h1>
      <p class="mt-4 font-hand text-2xl text-[color:var(--muted)]">
        Littérature → Environnement.
      </p>
      <p class="mt-6">
        <a class="go brutal-border" href={to} aria-label="Aller vers /environnement">Aller vers /environnement →</a>
      </p>
    </div>

    <meta http-equiv="refresh" content={`0; url=${to}`} />
    <script is:inline>
      window.location.replace('/environnement');
    </script>
  </main>
</BaseLayout>

<style>
  .go {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    font-weight: 900;
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    background: rgba(0, 0, 0, 0.55);
    border: 2px solid var(--fg);
    box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.6);
    color: rgba(246, 246, 246, 0.92);
    text-decoration: none;
  }

  .go:hover {
    background: rgba(0, 0, 0, 0.75);
  }
</style>
