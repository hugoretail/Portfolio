---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/withBase';

const INSTAGRAM_URL = 'https://www.instagram.com/kamen___n/';

const fallbackImg = withBase('/assets/images/graffiti-wall.svg');

type GraffPiece = {
  id: string;
  title: string;
  subtitle: string;
  year?: string;
  city?: string;
  src?: string;
  ig?: string;
};

// NOTE: replace `src` with your real photos later (e.g. /assets/graffiti/xxx.jpg)
const pieces: GraffPiece[] = [
  {
    id: 'fresque-1',
    title: 'Rève Un Ours !',
    year: '2025',
    city: 'Biganos',
    src: withBase('/assets/images/graffiti/kamen1.JPG')
  },
  {
    id: 'fresque-2',
    title: 'A la maison',
    year: '2025',
    city: 'Gujan-Mestras',
    src: withBase('/assets/images/graffiti/kamen5.JPG')
  },
  {
    id: 'fresque-3',
    title: 'Campulsations',
    year: '2025',
    city: 'Pessac',
    src: withBase('/assets/images/graffiti/kamen3.JPG')
  },
  {
    id: 'fresque-4',
    title: 'Le plus puissant',
    year: '2025',
    city: 'Pessac',
    src: withBase('/assets/images/graffiti/mutin1.JPG')
  },
  {
    id: 'fresque-5',
    title: 'Schtroumpfs',
    year: '2025',
    city: 'Biganos',
    src: withBase('/assets/images/graffiti/mutin2.JPG')
  },
  {
    id: 'fresque-6',
    title: 'Rooooule',
    year: '2025',
    city: 'Pessac',
    src: withBase('/assets/images/graffiti/kamen4.JPG')
  },
  {
    id: 'fresque-7',
    title: 'Lums Jaune',
    year: '2025',
    city: 'Pessac',
    src: withBase('/assets/images/graffiti/mutin4.JPG')
  },
  {
    id: 'fresque-8',
    title: 'Take A Look',
    year: '2025',
    city: 'Pessac',
    src: withBase('/assets/images/graffiti/mutin3.JPG')
  },
  {
    id: 'fresque-9',
    title: 'Violette',
    year: '2023',
    city: 'Gujan-Mestras',
    src: withBase('/assets/images/graffiti/kamen2.JPG')
  }
];
---

<BaseLayout title="Hugo — Graffiti" description="Blackbook interactif (flashlight + pages à tourner).">
  <div id="graffitiPage" class="graffiti-page relative min-h-screen overflow-hidden">
    <div class="pointer-events-none absolute inset-0 bg-graffiti opacity-25" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 bg-nature opacity-[0.08]" aria-hidden="true"></div>
    <div class="paper-grain" aria-hidden="true"></div>
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="graffiti-wallpaper" aria-hidden="true"></div>
    <div id="torch" class="torch" aria-hidden="true"></div>

    <a class="bb-backbtn brutal-border" href={withBase('/moi')} aria-label="Retour à /moi" title="Retour">
      <span aria-hidden="true">←</span>
    </a>

    <main class="relative z-10 mx-auto max-w-6xl px-4 pb-16 pt-8">
      <section class="bb-stage" aria-label="Blackbook">
        <a class="bb-ig ig-float" href={INSTAGRAM_URL} target="_blank" rel="noreferrer">Instagram ↗</a>
        <div class="bb-top" aria-hidden="true">
          <div class="bb-top__left">GRAFFITI / BLACKBOOK</div>
          <div class="bb-top__right">← → pour tourner</div>
        </div>

        <div class="bb-shell">
          <div
            id="bbBook"
            class="bb-book"
            tabindex="0"
            aria-label="Blackbook (L pour couper la lampe, flèches gauche/droite pour tourner)"
          >
            <div class="bb-book__spine" aria-hidden="true"></div>

            <div class="bb-book__halves">
              <div id="bbLeft" class="bb-half bb-half--left" aria-label="Page gauche"></div>
              <div id="bbRight" class="bb-half bb-half--right" aria-label="Page droite"></div>

              <div id="bbFlip" class="bb-flip" aria-hidden="true">
                <div class="bb-flip__face bb-flip__face--front"></div>
                <div class="bb-flip__face bb-flip__face--back"></div>
              </div>
            </div>

          </div>
        </div>

        <div id="bbTemplates" hidden>
          {pieces.map((p, idx) => (
            <article
              class="bb-sheet"
              data-page={String(idx)}
              data-title={p.title}
              data-subtitle={p.subtitle}
              data-year={p.year ?? ''}
              data-city={p.city ?? ''}
              data-src={p.src ?? ''}
              data-ig={p.ig ?? INSTAGRAM_URL}
            >
              <div class="sheet__top">
                <div class="sheet__num">{String(idx + 1).padStart(2, '0')}</div>
                <div class="sheet__micro">{(p.city ?? '—').toUpperCase()} • {p.year ?? '—'}</div>
              </div>

              <div class="sheet__tag">{p.title}</div>
              <div class="sheet__sub">{p.subtitle}</div>

              <button class="sheet__media" type="button" data-open aria-label={`Ouvrir ${p.title}`}>
                {p.src ? <img src={p.src} alt={p.title} loading="lazy" /> : <div class="sheet__ph" />}
                <span class="sheet__spray" aria-hidden="true"></span>
              </button>
            </article>
          ))}
        </div>
      </section>
    </main>

    <dialog id="graffitiModal" class="modal">
      <form method="dialog" class="modal__backdrop">
        <button aria-label="Fermer" class="modal__x" value="close" type="submit">✕</button>
        <div class="modal__panel brutal-border" role="document">
          <div class="modal__head">
            <div>
              <div class="modal__kicker">OUVRIR</div>
              <div id="mTitle" class="modal__title"></div>
              <div id="mSub" class="modal__sub"></div>
            </div>
            <a id="mIG" class="modal__ig" target="_blank" rel="noreferrer">Instagram ↗</a>
          </div>
          <div class="modal__media brutal-border">
            <img id="mImg" alt="" loading="lazy" />
          </div>
          <div class="modal__foot">
            <div class="modal__hint">Esc pour fermer</div>
            <button class="tool" value="close" type="submit">Fermer</button>
          </div>
        </div>
      </form>
    </dialog>
  </div>

  <script is:inline define:vars={{ fallbackImg }}>
    (() => {
      const page = document.getElementById('graffitiPage');
      const book = document.getElementById('bbBook');
      const left = document.getElementById('bbLeft');
      const right = document.getElementById('bbRight');
      const flip = document.getElementById('bbFlip');
      const torch = document.getElementById('torch');
      const templatesRoot = document.getElementById('bbTemplates');
      const modal = document.getElementById('graffitiModal');
      const mTitle = document.getElementById('mTitle');
      const mSub = document.getElementById('mSub');
      const mImg = document.getElementById('mImg');
      const mIG = document.getElementById('mIG');

      if (!page || !book || !left || !right || !flip || !torch || !templatesRoot) return;

      const prefersReducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches ?? false;
      const motionScale = prefersReducedMotion ? 0.72 : 1;
      const STORAGE_KEY = 'graffiti.blackbook.rightPage.v2';

      const sheets = Array.from(templatesRoot.querySelectorAll('.bb-sheet'));
      const flipFront = flip.querySelector('.bb-flip__face--front');
      const flipBack = flip.querySelector('.bb-flip__face--back');

      const clamp = (n, a, b) => Math.max(a, Math.min(b, n));

      const readSavedPage = () => {
        try {
          const raw = window.localStorage.getItem(STORAGE_KEY);
          if (!raw) return 0;
          const n = parseInt(raw, 10);
          if (!Number.isFinite(n)) return 0;
          // Align to our spread model (step by 2). Allow the special end state == sheets.length.
          if (n >= sheets.length) return sheets.length;
          return n - (n % 2);
        } catch {
          return 0;
        }
      };

      const writeSavedPage = (n) => {
        try {
          window.localStorage.setItem(STORAGE_KEY, String(n));
        } catch {
          // ignore
        }
      };

      // Lamp / torch
      let lampEnabled = true;
      const setLampEnabled = (on) => {
        lampEnabled = !!on;
        page.classList.toggle('is-night', lampEnabled);
      };
      setLampEnabled(true);

      const setTorchAt = (clientX, clientY) => {
        const r = page.getBoundingClientRect();
        const x = clamp(clientX - r.left, 0, r.width);
        const y = clamp(clientY - r.top, 0, r.height);
        // tiny jitter (hand feel) when lamp is on
        const jx = lampEnabled ? (Math.sin(performance.now() / 110) * 2.2) : 0;
        const jy = lampEnabled ? (Math.cos(performance.now() / 140) * 1.8) : 0;
        torch.style.setProperty('--mx', `${x + jx}px`);
        torch.style.setProperty('--my', `${y + jy}px`);
      };

      // Default torch position
      {
        const r = page.getBoundingClientRect();
        setTorchAt(r.left + r.width * 0.52, r.top + r.height * 0.28);
      }

      let raf = 0;
      let lastMove = null;
      const scheduleTorch = () => {
        if (raf) return;
        raf = window.requestAnimationFrame(() => {
          raf = 0;
          if (!lastMove) return;
          setTorchAt(lastMove.x, lastMove.y);
        });
      };

      window.addEventListener(
        'pointermove',
        (e) => {
          if (e.pointerType === 'touch') return;
          lastMove = { x: e.clientX, y: e.clientY };
          scheduleTorch();
        },
        { passive: true }
      );

      window.addEventListener(
        'pointerdown',
        (e) => {
          if (e.pointerType === 'touch') {
            lastMove = { x: e.clientX, y: e.clientY };
            scheduleTorch();
          }
        },
        { passive: true }
      );

      window.addEventListener('keydown', (e) => {
        if (e.key !== 'l' && e.key !== 'L') return;
        const t = e.target;
        const tag = t?.tagName?.toLowerCase?.();
        if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
        e.preventDefault();
        setLampEnabled(!lampEnabled);
      });

      // Modal
      const setModalOpen = (on) => {
        document.documentElement.classList.toggle('is-modal-open', !!on);
        document.body.classList.toggle('is-modal-open', !!on);
      };

      const openModal = (el) => {
        if (!modal || !mTitle || !mSub || !mImg || !mIG) return;
        const title = el.getAttribute('data-title') || 'Graffiti';
        const subtitle = el.getAttribute('data-subtitle') || '';
        const year = el.getAttribute('data-year') || '';
        const city = el.getAttribute('data-city') || '';
        const src = el.getAttribute('data-src') || '';
        const ig = el.getAttribute('data-ig') || '';
        mTitle.textContent = title;
        mSub.textContent = [subtitle, city, year].filter(Boolean).join(' · ');
        mIG.setAttribute('href', ig || 'https://www.instagram.com/kamen___n/');
        mImg.src = src || fallbackImg;
        mImg.alt = title;
        try {
          if (typeof modal.showModal === 'function') modal.showModal();
          else modal.setAttribute('open', 'true');
        } catch {
          modal.setAttribute('open', 'true');
        }
        setModalOpen(true);
      };

      if (modal) {
        modal.addEventListener('close', () => setModalOpen(false));
        modal.addEventListener('cancel', () => setModalOpen(false));
      }

      // Book rendering
      const makeBlank = (side) => {
        const el = document.createElement('div');
        el.className = `bb-blank bb-blank--${side}`;
        if (side === 'left') {
          el.innerHTML = `
            <div class="blank__mark">Kamen</div>
            <div class="blank__sub">BLACKBOOK</div>
            <div class="blank__fine">Navigue sur les pages en cliquant, ou en utilisant les flèches ~</div>
          `;
        } else {
          el.innerHTML = `
            <div class="blank__mark">—</div>
            <div class="blank__sub">page vide</div>
            <div class="blank__fine">(pas encore taguée)</div>
          `;
        }
        return el;
      };

      const cloneSheet = (idx) => {
        if (idx < 0 || idx >= sheets.length) return null;
        return sheets[idx].cloneNode(true);
      };

      const mount = (host, node) => {
        host.replaceChildren();
        if (node) host.appendChild(node);
      };

      // rightIdx is the index of the RIGHT page of the current spread.
      // Special case: rightIdx === sheets.length means "blank right page" (end / back cover).
      let rightIdx = clamp(readSavedPage(), 0, sheets.length);
      let flipping = false;
      let activeTurn = null;
      let turnAnim = null;

      const renderSpread = () => {
        const leftIdx = rightIdx - 1;
        const leftNode = leftIdx < 0 ? makeBlank('left') : cloneSheet(leftIdx);
        const rightNode = rightIdx >= sheets.length ? makeBlank('right') : (cloneSheet(rightIdx) ?? makeBlank('right'));
        mount(left, leftNode);
        mount(right, rightNode);
      };

      const prepareFlipFaces = (frontNode, backNode) => {
        if (!flipFront || !flipBack) return;
        flipFront.replaceChildren(frontNode);
        // Important: show a real face on the back too.
        // Otherwise some browsers briefly show the front face mirrored near the end of the turn.
        flipBack.replaceChildren(backNode ?? document.createElement('div'));
      };

      const targetRightIdxFor = (dir) => {
        if (dir === 'next') return Math.min(rightIdx + 2, sheets.length);
        return Math.max(rightIdx - 2, 0);
      };

      const canTurn = (dir) => targetRightIdxFor(dir) !== rightIdx;

      const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);
      const angleFor = (dir) => (dir === 'next' ? -178 : 178);
      const sxFor = (dir) => (dir === 'next' ? -1 : 1);

      const applyFlipPose = (dir, p) => {
        if (!flip) return;
        const pp = clamp(p, 0, 1);
        const lift = Math.sin(Math.PI * pp); // 0..1..0
        const angle = angleFor(dir);
        const sx = sxFor(dir);

        flip.style.setProperty('--p', pp.toFixed(4));
        flip.style.setProperty('--ry', `${(pp * angle).toFixed(3)}deg`);
        flip.style.setProperty('--z', `${(lift * 46).toFixed(2)}px`);
        flip.style.setProperty('--tx', `${(sx * lift * 26).toFixed(2)}px`);
        flip.style.setProperty('--rz', `${(sx * -lift * 4.2).toFixed(3)}deg`);
        flip.style.setProperty('--curl', lift.toFixed(4));
      };

      const startTurn = (dir) => {
        if (flipping) return false;
        if (!canTurn(dir)) return false;
        if (!flipFront || !flipBack) return false;
        // Do not bail on display:none (responsive CSS). If it is hidden, we still keep
        // the state consistent and fallback will be handled elsewhere.

        flipping = true;
        book.classList.add('is-flipping');

        const currentLeft = left.firstElementChild?.cloneNode(true) ?? makeBlank('left');
        const currentRight = right.firstElementChild?.cloneNode(true) ?? makeBlank('right');

        const targetRightIdx = targetRightIdxFor(dir);

        const nodeFor = (idx, side) => {
          if (idx < 0 || idx >= sheets.length) return makeBlank(side);
          return cloneSheet(idx) ?? makeBlank(side);
        };

        flip.classList.remove('is-next', 'is-prev');
        flip.classList.add(dir === 'next' ? 'is-next' : 'is-prev');
        flip.classList.add('is-dragging');
        flip.hidden = false;
        applyFlipPose(dir, 0);

        if (dir === 'next') {
          // Real-book timing:
          // - Right (under) page becomes visible immediately as soon as you lift.
          // - Left page updates only when the turned sheet lands.
          const underRight = nodeFor(targetRightIdx, 'right');
          mount(right, underRight);

          const landingLeft = nodeFor(rightIdx + 1, 'left');
          prepareFlipFaces(currentRight, landingLeft);
        } else {
          // Real-book timing (reverse):
          // - Left (under) page becomes visible immediately.
          // - Right page updates only when the turned sheet lands.
          const underLeft = nodeFor(targetRightIdx - 1, 'left');
          mount(left, underLeft);

          const landingRight = nodeFor(rightIdx - 2, 'right');
          prepareFlipFaces(currentLeft, landingRight);
        }

        activeTurn = { dir, p: 0, targetRightIdx };
        return true;
      };

      const finishTurn = ({ commit }) => {
        if (!activeTurn) return;
        const dir = activeTurn.dir;
        flip.hidden = true;
        flip.classList.remove('is-next', 'is-prev', 'is-dragging');
        flip.style.removeProperty('--p');
        flip.style.removeProperty('--ry');
        flip.style.removeProperty('--z');
        flip.style.removeProperty('--tx');
        flip.style.removeProperty('--rz');
        flip.style.removeProperty('--curl');
        book.classList.remove('is-flipping');
        if (commit) {
          rightIdx = clamp(activeTurn.targetRightIdx ?? rightIdx, 0, sheets.length);
          writeSavedPage(rightIdx);
        }
        renderSpread();
        activeTurn = null;
        flipping = false;
      };

      const cancelTurnAnim = () => {
        if (!turnAnim) return;
        try { cancelAnimationFrame(turnAnim.raf); } catch {}
        turnAnim = null;
      };

      const animateTurnTo = (targetP, { duration = 780 } = {}) => {
        if (!activeTurn) return;
        cancelTurnAnim();
        const dir = activeTurn.dir;
        const from = clamp(activeTurn.p ?? 0, 0, 1);
        const to = clamp(targetP, 0, 1);
        const start = performance.now();
        const dur = Math.max(220, duration * motionScale);

        const step = (now) => {
          if (!activeTurn) return;
          const t = clamp((now - start) / dur, 0, 1);
          const k = easeOutCubic(t);
          const p = from + (to - from) * k;
          activeTurn.p = p;
          applyFlipPose(dir, p);
          if (t < 1) {
            turnAnim.raf = requestAnimationFrame(step);
            return;
          }
          activeTurn.p = to;
          applyFlipPose(dir, to);
          turnAnim = null;
          finishTurn({ commit: to >= 1 && targetP >= 1 });
        };

        turnAnim = { raf: requestAnimationFrame(step) };
      };

      const runFlip = (dir) => {
        if (!startTurn(dir)) return false;
        // JS-driven turn: always visible (lift/curl + slower)
        requestAnimationFrame(() => {
          if (!activeTurn) return;
          animateTurnTo(1, { duration: 980 });
        });
        return true;
      };

      const turnNext = () => {
        if (flipping) return;
        if (runFlip('next')) return;
        const target = Math.min(rightIdx + 2, sheets.length);
        if (target !== rightIdx) {
          rightIdx = target;
          writeSavedPage(rightIdx);
          renderSpread();
        }
      };

      const turnPrev = () => {
        if (flipping) return;
        if (runFlip('prev')) return;
        const target = Math.max(rightIdx - 2, 0);
        if (target !== rightIdx) {
          rightIdx = target;
          writeSavedPage(rightIdx);
          renderSpread();
        }
      };

      renderSpread();
      flip.hidden = true;

      const isInteractiveTarget = (t) => !!t?.closest?.('a, button, input, textarea, select, [data-open]');

      book.addEventListener('click', (e) => {
        const btn = e.target?.closest?.('[data-open]');
        if (btn) {
          const sheetEl = btn.closest('.bb-sheet');
          if (sheetEl) openModal(sheetEl);
          return;
        }
        if (modal?.open) return;
        if (isInteractiveTarget(e.target)) return;
        if (flipping) return;

        const r = book.getBoundingClientRect();
        const x = e.clientX - r.left;
        if (x > r.width / 2) turnNext();
        else turnPrev();
      });

      let drag = null;
      book.addEventListener('pointerdown', (e) => {
        if (modal?.open) return;
        if (isInteractiveTarget(e.target)) return;
        if (flipping) return;

        const r = book.getBoundingClientRect();
        const x = e.clientX - r.left;
        const dir = x > r.width / 2 ? 'next' : 'prev';
        if (!canTurn(dir)) return;

        drag = { id: e.pointerId, x0: e.clientX, y0: e.clientY, widthHalf: r.width / 2, dir, started: false, p: 0 };
        try {
          book.setPointerCapture(e.pointerId);
        } catch {}
      });

      book.addEventListener('pointermove', (e) => {
        if (!drag || e.pointerId !== drag.id) return;
        const dx = e.clientX - drag.x0;
        const dy = e.clientY - drag.y0;
        if (Math.abs(dy) > 160) return;

        if (!drag.started) {
          const wantsStart = Math.abs(dx) > 10 && Math.abs(dy) < 80;
          if (!wantsStart) return;
          if (!startTurn(drag.dir)) {
            drag = null;
            return;
          }
          drag.started = true;
        }

        const denom = Math.max(180, drag.widthHalf * 0.92);
        let p = 0;
        if (drag.dir === 'next') p = clamp((-dx) / denom, 0, 1);
        else p = clamp((dx) / denom, 0, 1);

        drag.p = p;
        activeTurn && (activeTurn.p = p);
        applyFlipPose(drag.dir, p);
      });

      const finishDrag = () => {
        if (!drag) return;
        if (!drag.started) {
          drag = null;
          return;
        }
        const commit = drag.p > 0.52;
        drag = null;
        if (!activeTurn) return;
        animateTurnTo(commit ? 1 : 0, { duration: commit ? 540 : 420 });
      };

      book.addEventListener('pointerup', finishDrag);
      book.addEventListener('pointercancel', finishDrag);

      const onTurnKey = (e) => {
        if (modal?.open) return;
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          turnPrev();
        }
        if (e.key === 'ArrowRight') {
          e.preventDefault();
          turnNext();
        }
      };
      book.addEventListener('keydown', onTurnKey);
      window.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
        const t = e.target;
        const tag = t?.tagName?.toLowerCase?.();
        if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
        onTurnKey(e);
      });
    })();
  </script>

  <style is:global>
    .graffiti-page {
      --ink: rgba(0,0,0,0.92);
      --paper: #efe7d2;
      --paper2: #e3d8bf;
      --accent: #ff0000;
      --neon: #ffe600;
      --steel: rgba(246,246,246,0.65);
      /* wider flashlight */
      --torch-hole: 680px;
      --torch-soft: 1480px;
      --torch-glow: 560px;
    }

    html.is-modal-open,
    body.is-modal-open {
      overflow: hidden;
    }

    .graffiti-wallpaper {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        var(--img-graffiti-texture) center / cover no-repeat,
        radial-gradient(1100px 800px at 12% 22%, rgba(255, 0, 0, 0.09), transparent 62%),
        radial-gradient(900px 780px at 85% 30%, rgba(255, 230, 0, 0.05), transparent 60%),
        radial-gradient(1100px 800px at 68% 84%, rgba(0, 209, 255, 0.05), transparent 65%);
      opacity: 0.36;
      mix-blend-mode: overlay;
      filter: contrast(1.12) saturate(1.18);
    }

    .bb-stage { margin-top: 18px; }
    .bb-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      font-weight: 900;
      font-size: 10px;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: rgba(246,246,246,0.55);
    }
    .bb-top__left { color: rgba(255,230,0,0.62); }
    .bb-top__right { text-align: right; }

    .bb-shell {
      margin-top: 16px;
      display: grid;
      place-items: center;
      min-height: min(860px, 78vh);
    }

    .ig-float {
      position: fixed;
      top: 18px;
      right: 18px;
      z-index: 60;
    }

    .bb-backbtn {
      position: fixed;
      top: 18px;
      left: 18px;
      z-index: 60;
      display: inline-grid;
      place-items: center;
      width: 44px;
      height: 44px;
      background: rgba(0,0,0,0.60);
      border: 2px solid rgba(246,246,246,0.45);
      color: rgba(246,246,246,0.88);
      font-weight: 900;
      font-size: 18px;
      line-height: 1;
      text-decoration: none;
      box-shadow: 8px 8px 0 rgba(0,0,0,0.60);
      transition: background 140ms ease, transform 140ms ease;
    }

    .bb-backbtn:hover {
      background: rgba(0,0,0,0.72);
      transform: translateY(-1px);
    }

    @media (max-width: 860px) {
      .ig-float {
        top: 12px;
        right: 12px;
        padding: 7px 9px;
        font-size: 10px;
        letter-spacing: 0.18em;
      }

      .bb-backbtn {
        top: 12px;
        left: 12px;
        width: 40px;
        height: 40px;
      }
    }

    .bb-book {
      position: relative;
      width: min(980px, 94vw);
      height: min(620px, 70vh);
      border: 2px solid rgba(246,246,246,0.45);
      box-shadow: 18px 18px 0 rgba(0,0,0,0.62);
      border-radius: 6px;
      /* cover texture (no visible "striped" band around pages) */
      background:
        /* big grime / vignettes */
        radial-gradient(900px 520px at 0% 0%, rgba(0,209,255,0.05), transparent 62%),
        radial-gradient(900px 520px at 100% 0%, rgba(255,0,0,0.06), transparent 64%),
        radial-gradient(1200px 720px at 50% 120%, rgba(0,0,0,0.55), transparent 66%),

        /* paint splats (irregular blobs via multiple overlapping ellipses) */
        radial-gradient(68px 44px at 14% 74%, rgba(255, 0, 0, 0.30), transparent 72%),
        radial-gradient(42px 30px at 16% 76%, rgba(255, 0, 0, 0.24), transparent 70%),
        radial-gradient(28px 22px at 12% 78%, rgba(255, 0, 0, 0.20), transparent 72%),
        radial-gradient(16px 90px at 17% 84%, rgba(255, 0, 0, 0.20), transparent 64%),

        radial-gradient(54px 40px at 88% 26%, rgba(255, 230, 0, 0.28), transparent 74%),
        radial-gradient(34px 26px at 86% 24%, rgba(255, 230, 0, 0.22), transparent 72%),
        radial-gradient(18px 70px at 90% 33%, rgba(255, 230, 0, 0.18), transparent 66%),

        radial-gradient(62px 46px at 74% 78%, rgba(0, 209, 255, 0.24), transparent 74%),
        radial-gradient(38px 28px at 72% 76%, rgba(0, 209, 255, 0.20), transparent 72%),
        radial-gradient(22px 18px at 78% 80%, rgba(0, 209, 255, 0.16), transparent 72%),

        /* corner marks so you still see splats with a thinner frame */
        radial-gradient(44px 34px at 6% 12%, rgba(255, 0, 0, 0.18), transparent 76%),
        radial-gradient(36px 28px at 95% 90%, rgba(255, 230, 0, 0.16), transparent 78%),
        radial-gradient(40px 30px at 95% 12%, rgba(0, 209, 255, 0.14), transparent 78%),

        /* micro speckles (ink dust) */
        radial-gradient(1.4px 1.4px at 12% 18%, rgba(255,255,255,0.06), transparent 60%),
        radial-gradient(1.2px 1.2px at 18% 46%, rgba(255,255,255,0.05), transparent 60%),
        radial-gradient(1.1px 1.1px at 26% 66%, rgba(255,255,255,0.04), transparent 60%),
        radial-gradient(1.2px 1.2px at 33% 32%, rgba(255,255,255,0.05), transparent 60%),
        radial-gradient(1.6px 1.6px at 44% 22%, rgba(255,255,255,0.05), transparent 62%),
        radial-gradient(1.3px 1.3px at 52% 54%, rgba(255,255,255,0.04), transparent 62%),
        radial-gradient(1.2px 1.2px at 61% 38%, rgba(255,255,255,0.05), transparent 62%),
        radial-gradient(1.4px 1.4px at 68% 64%, rgba(255,255,255,0.04), transparent 62%),
        radial-gradient(1.2px 1.2px at 76% 44%, rgba(255,255,255,0.05), transparent 62%),
        radial-gradient(1.3px 1.3px at 84% 58%, rgba(255,255,255,0.04), transparent 62%),
        radial-gradient(1.1px 1.1px at 90% 18%, rgba(255,255,255,0.05), transparent 62%),

        /* base cover */
        linear-gradient(180deg, rgba(18,18,18,0.72), rgba(0,0,0,0.52));
      outline: none;
      perspective: 1100px;
      transform-style: preserve-3d;
      isolation: isolate;
    }

    .bb-book::after {
      content: '';
      position: absolute;
      inset: 8px;
      pointer-events: none;
      border-radius: 4px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.07), rgba(255,255,255,0.00) 34%),
        linear-gradient(90deg, rgba(0,0,0,0.0) 0 92%, rgba(255,255,255,0.08) 92% 100%),
        linear-gradient(180deg, rgba(0,0,0,0.0) 0 92%, rgba(255,255,255,0.08) 92% 100%);
      opacity: 0.9;
      mix-blend-mode: overlay;
    }

    .bb-book::before {
      content: '';
      position: absolute;
      inset: 8px;
      border: 2px solid rgba(246,246,246,0.18);
      pointer-events: none;
    }

    .bb-book__spine {
      position: absolute;
      left: calc(50% - 14px);
      top: 0;
      bottom: 0;
      width: 28px;
      background:
        linear-gradient(90deg, rgba(0,0,0,0.75), rgba(255,255,255,0.08), rgba(0,0,0,0.72)),
        repeating-linear-gradient(0deg, rgba(255,230,0,0.10) 0 2px, transparent 2px 10px);
      opacity: 0.9;
      mix-blend-mode: multiply;
      pointer-events: none;
      transform: translateZ(8px);
      z-index: 8;
    }

    /* paint splats live on paper, not on the cover */

    .bb-ig {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 10px;
      border: 2px solid rgba(255,230,0,0.65);
      background: rgba(0,0,0,0.60);
      color: rgba(255,230,0,0.90);
      font-weight: 900;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      box-shadow: 8px 8px 0 rgba(0,0,0,0.60);
    }

    .bb-book__halves {
      position: absolute;
      left: 10px;
      right: 10px;
      top: 10px;
      bottom: 10px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      transform: translateZ(14px);
      z-index: 6;
    }

    .bb-book__halves::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(90px 600px at 50% 50%, rgba(0,0,0,0.22), rgba(0,0,0,0.0) 68%),
        linear-gradient(90deg, rgba(0,0,0,0.0) 48.5%, rgba(0,0,0,0.08) 50%, rgba(0,0,0,0.0) 51.5%);
      mix-blend-mode: multiply;
      opacity: 0.85;
      z-index: 2;
    }

    .bb-half {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(1200px 800px at 20% 30%, rgba(0,0,0,0.06), transparent 60%),
        linear-gradient(180deg, var(--paper), var(--paper2));
      color: var(--ink);
      padding: 18px 18px 14px;
      filter: contrast(1.05) saturate(1.05);
      border-radius: 2px;
    }

    .bb-half::after {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.55;
      mix-blend-mode: multiply;
    }

    .bb-half--left::after {
      background: linear-gradient(90deg, rgba(0,0,0,0.00), rgba(0,0,0,0.08) 74%, rgba(0,0,0,0.14));
    }

    .bb-half--right::after {
      background: linear-gradient(270deg, rgba(0,0,0,0.00), rgba(0,0,0,0.08) 74%, rgba(0,0,0,0.14));
    }

    .bb-half::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        /* folds / creases (subtle) */
        linear-gradient(115deg, transparent 0 46%, rgba(0,0,0,0.08) 47%, rgba(0,0,0,0.00) 52%, transparent 53% 100%),
        linear-gradient(62deg, transparent 0 58%, rgba(0,0,0,0.06) 59%, rgba(0,0,0,0.00) 63%, transparent 64% 100%),
        radial-gradient(520px 140px at 52% 14%, rgba(0,0,0,0.06), transparent 62%),
        /* tiny paint flecks on paper (very subtle, avoid "dots") */
        radial-gradient(22px 12px at 8% 18%, rgba(160, 10, 10, 0.06), transparent 74%),
        radial-gradient(14px 10px at 10% 20%, rgba(160, 10, 10, 0.04), transparent 74%),
        radial-gradient(16px 10px at 86% 74%, rgba(40, 150, 170, 0.04), transparent 76%),
        repeating-linear-gradient(0deg, rgba(0,0,0,0.04) 0 1px, transparent 1px 28px),
        radial-gradient(700px 500px at 50% 40%, rgba(0,0,0,0.10), transparent 60%);
      opacity: 0.34;
      pointer-events: none;
      mix-blend-mode: multiply;
    }

    .bb-half--left { border-right: 2px solid rgba(0,0,0,0.12); }
    .bb-half--right { border-left: 2px solid rgba(0,0,0,0.10); }
    .bb-half > * { position: relative; z-index: 1; }

    .bb-flip {
      --p: 0;
      position: absolute;
      top: 0;
      bottom: 0;
      width: 50%;
      z-index: 5;
      transform-style: preserve-3d;
      transform:
        translateX(var(--tx, 0px))
        translateZ(var(--z, 0px))
        rotateZ(var(--rz, 0deg))
        rotateY(var(--ry, 0deg));
      transition: none;
      filter: drop-shadow(0 22px 22px rgba(0,0,0,0.48));
    }

    .bb-flip.is-next { left: 50%; transform-origin: left center; }
    .bb-flip.is-prev { left: 0%; transform-origin: right center; }

    .bb-flip.is-dragging { transition: none; }

    .bb-flip__face {
      position: absolute;
      inset: 0;
      overflow: hidden;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      transform-style: preserve-3d;
      background:
        radial-gradient(1200px 800px at 20% 30%, rgba(0,0,0,0.06), transparent 60%),
        linear-gradient(180deg, var(--paper), var(--paper2));
      color: var(--ink);
      padding: 18px 18px 14px;
    }

    .bb-flip__face::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        /* folds / creases (match page texture) */
        linear-gradient(115deg, transparent 0 46%, rgba(0,0,0,0.08) 47%, rgba(0,0,0,0.00) 52%, transparent 53% 100%),
        linear-gradient(62deg, transparent 0 58%, rgba(0,0,0,0.06) 59%, rgba(0,0,0,0.00) 63%, transparent 64% 100%),
        radial-gradient(520px 140px at 52% 14%, rgba(0,0,0,0.06), transparent 62%),
        radial-gradient(22px 12px at 8% 18%, rgba(160, 10, 10, 0.06), transparent 74%),
        radial-gradient(14px 10px at 10% 20%, rgba(160, 10, 10, 0.04), transparent 74%),
        radial-gradient(16px 10px at 86% 74%, rgba(40, 150, 170, 0.04), transparent 76%),
        repeating-linear-gradient(0deg, rgba(0,0,0,0.04) 0 1px, transparent 1px 28px),
        radial-gradient(700px 500px at 50% 40%, rgba(0,0,0,0.10), transparent 60%);
      pointer-events: none;
      opacity: 0.34;
      mix-blend-mode: multiply;
    }

    .bb-flip__face > * { position: relative; z-index: 1; }
    .bb-flip__face--back { transform: rotateY(180deg); }

    .bb-flip::after {
      content: '';
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, rgba(0,0,0,0.0), rgba(0,0,0,0.58), rgba(0,0,0,0.0));
      opacity: calc(var(--curl, 0) * 1.05);
      transition: none;
      pointer-events: none;
      mix-blend-mode: multiply;
    }

    .bb-flip::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(240px 600px at 50% 50%, rgba(255,255,255,0.18), rgba(255,255,255,0.00) 70%),
        linear-gradient(90deg, rgba(255,255,255,0.0), rgba(255,255,255,0.18), rgba(255,255,255,0.0));
      opacity: calc(var(--curl, 0) * 0.90);
      mix-blend-mode: screen;
      transition: none;
    }

    .bb-blank { position: relative; height: 100%; display: grid; align-content: center; gap: 10px; }

    .bb-blank::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0.22;
      mix-blend-mode: multiply;
      filter: blur(0.4px) contrast(1.08) saturate(1.02);
      background:
        radial-gradient(120px 64px at 18% 22%, rgba(150, 15, 15, 0.14), transparent 74%),
        radial-gradient(90px 54px at 22% 26%, rgba(150, 15, 15, 0.10), transparent 74%),
        radial-gradient(70px 40px at 78% 78%, rgba(30, 120, 135, 0.10), transparent 76%),
        radial-gradient(36px 120px at 82% 64%, rgba(190, 170, 40, 0.08), transparent 76%),
        radial-gradient(2px 2px at 26% 18%, rgba(0,0,0,0.10), transparent 62%),
        radial-gradient(2px 2px at 34% 42%, rgba(0,0,0,0.08), transparent 62%),
        radial-gradient(2px 2px at 68% 76%, rgba(0,0,0,0.08), transparent 62%);
    }
    .blank__mark {
      font-family: var(--font-display, 'Bebas Neue', system-ui, sans-serif);
      font-size: clamp(64px, 7vw, 120px);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.86);
      text-shadow: 2px 2px 0 rgba(255,0,0,0.25);
    }

    .blank__sub { font-weight: 900; font-size: 12px; letter-spacing: 0.30em; text-transform: uppercase; opacity: 0.75; }
    .blank__fine { font-weight: 800; font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.55; }

    .bb-sheet { position: relative; height: 100%; display: grid; grid-template-rows: auto auto auto 1fr; gap: 14px; }

    .bb-sheet::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      /* clearly visible paint on paper (still keeps text readable) */
      opacity: 0.56;
      mix-blend-mode: multiply;
      filter: blur(0.35px) contrast(1.14) saturate(1.06);
      background:
        /* red dried splat (irregular) */
        radial-gradient(180px 86px at 14% 18%, rgba(150, 15, 15, 0.24), transparent 72%),
        radial-gradient(110px 70px at 18% 22%, rgba(150, 15, 15, 0.18), transparent 74%),
        radial-gradient(62px 44px at 24% 30%, rgba(150, 15, 15, 0.12), transparent 76%),
        radial-gradient(14px 110px at 18% 42%, rgba(150, 15, 15, 0.10), transparent 74%),

        /* red drift along the mid */
        radial-gradient(200px 120px at 30% 62%, rgba(150, 15, 15, 0.10), transparent 76%),

        /* yellow stain */
        radial-gradient(150px 72px at 84% 16%, rgba(190, 170, 40, 0.16), transparent 74%),
        radial-gradient(90px 56px at 80% 20%, rgba(190, 170, 40, 0.12), transparent 76%),
        radial-gradient(18px 130px at 88% 32%, rgba(190, 170, 40, 0.10), transparent 76%),

        /* cyan smear */
        radial-gradient(150px 76px at 82% 86%, rgba(30, 120, 135, 0.14), transparent 76%),
        radial-gradient(92px 58px at 76% 82%, rgba(30, 120, 135, 0.10), transparent 76%),

        /* bottom-left grime */
        radial-gradient(220px 160px at 22% 92%, rgba(0,0,0,0.10), transparent 74%),

        /* specks */
        radial-gradient(2px 2px at 26% 14%, rgba(0,0,0,0.16), transparent 62%),
        radial-gradient(2px 2px at 32% 18%, rgba(0,0,0,0.14), transparent 62%),
        radial-gradient(1.6px 1.6px at 44% 26%, rgba(0,0,0,0.14), transparent 62%),
        radial-gradient(2px 2px at 62% 74%, rgba(0,0,0,0.14), transparent 62%),
        radial-gradient(1.6px 1.6px at 70% 78%, rgba(0,0,0,0.14), transparent 62%),
        radial-gradient(2px 2px at 76% 82%, rgba(0,0,0,0.14), transparent 62%);
    }

    .bb-sheet > * { position: relative; z-index: 1; }
    .sheet__top { display: flex; justify-content: space-between; align-items: baseline; gap: 10px; }
    .sheet__num { font-weight: 900; font-size: 11px; letter-spacing: 0.26em; text-transform: uppercase; opacity: 0.8; }
    .sheet__micro { font-weight: 900; font-size: 10px; letter-spacing: 0.28em; text-transform: uppercase; opacity: 0.55; }

    .sheet__tag {
      margin-top: 4px;
      font-family: var(--font-display, 'Bebas Neue', system-ui, sans-serif);
      font-size: clamp(44px, 5.2vw, 72px);
      line-height: 0.92;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.90);
      text-shadow: 2px 2px 0 rgba(255,0,0,0.22);
    }

    .sheet__sub {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace;
      font-weight: 800;
      font-size: 12px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      opacity: 0.70;
    }

    .sheet__media {
      position: relative;
      width: 100%;
      aspect-ratio: 16 / 9;
      border: 2px solid rgba(0,0,0,0.28);
      background: rgba(0,0,0,0.10);
      padding: 0;
      overflow: hidden;
      cursor: zoom-in;
    }

    .sheet__media img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      background: rgba(239,231,210,0.55);
      filter: contrast(1.06) saturate(1.02);
    }

    .sheet__ph { height: 100%; background: linear-gradient(135deg, rgba(0,0,0,0.10), rgba(0,0,0,0.02)); }

    .sheet__spray {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(280px 200px at 30% 20%, rgba(255,0,0,0.06), transparent 60%),
        radial-gradient(260px 220px at 70% 75%, rgba(0,209,255,0.05), transparent 60%),
        radial-gradient(200px 200px at 55% 40%, rgba(255,230,0,0.05), transparent 55%);
      mix-blend-mode: multiply;
      opacity: 0.75;
    }

    /* (removed) old right-column blocks/cipher/foot */

    .bb-back { height: 100%; display: grid; place-items: center; }

    .bb-back__smudge {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(320px 240px at 35% 40%, rgba(0,0,0,0.10), transparent 65%),
        radial-gradient(340px 260px at 70% 65%, rgba(255,0,0,0.06), transparent 68%),
        radial-gradient(220px 220px at 60% 20%, rgba(0,209,255,0.05), transparent 70%);
      opacity: 0.65;
      pointer-events: none;
      mix-blend-mode: multiply;
    }

    .bb-back__ghost {
      position: relative;
      font-weight: 900;
      font-size: 11px;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: rgba(0,0,0,0.25);
    }

    .modal { border: none; background: transparent; padding: 0; max-width: none; max-height: none; }
    .modal::backdrop { background: rgba(0,0,0,0.68); }
    .modal__backdrop {
      width: 100%;
      height: 100%;
      display: grid;
      place-items: center;
      padding: 18px;
      box-sizing: border-box;
      overflow: hidden;
    }
    .modal__panel {
      max-width: min(980px, 92vw);
      width: 100%;
      max-height: calc(100vh - 36px);
      overflow: auto;
      background: rgba(0,0,0,0.62);
      padding: 14px;
      box-shadow: 18px 18px 0 rgba(0,0,0,0.60);
    }
    .modal__x { position: fixed; right: 16px; top: 16px; width: 44px; height: 44px; border: 2px solid var(--fg); background: rgba(0,0,0,0.55); color: var(--fg); font-weight: 900; }
    .modal__head { display: flex; align-items: start; justify-content: space-between; gap: 12px; }
    .modal__kicker { font-size: 10px; letter-spacing: 0.35em; text-transform: uppercase; font-weight: 900; color: rgba(246,246,246,0.65); }
    .modal__title { font-family: var(--font-display, 'Bebas Neue', system-ui, sans-serif); font-size: 54px; line-height: 1; margin-top: 6px; }
    .modal__sub { margin-top: 6px; font-weight: 900; font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase; color: rgba(255,230,0,0.78); }
    .modal__ig {
      margin-top: 8px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 12px;
      border: 2px solid rgba(255,230,0,0.65);
      background: rgba(0,0,0,0.55);
      color: rgba(255,230,0,0.92);
      text-decoration: none;
      white-space: nowrap;
      font-weight: 900;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      box-shadow: 8px 8px 0 rgba(0,0,0,0.55);
    }
    .modal__media { margin-top: 12px; background: rgba(0,0,0,0.55); }
    .modal__media img { display: block; width: 100%; height: min(60vh, 520px); object-fit: cover; opacity: 0.96; }
    .modal__foot { margin-top: 12px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .modal__hint { font-size: 12px; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(246,246,246,0.58); }

    .torch {
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 40;
      opacity: 0;
      transition: opacity 180ms ease;
      background:
        radial-gradient(circle var(--torch-hole) at var(--mx, 50%) var(--my, 50%), rgba(0,0,0,0.00) 0%, rgba(0,0,0,0.14) 40%, rgba(0,0,0,0.90) 72%, rgba(0,0,0,0.98) 100%),
        radial-gradient(1400px 900px at 50% 20%, rgba(0,0,0,0.20), rgba(0,0,0,0.55) 50%, rgba(0,0,0,0.78) 100%);
    }

    .torch::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle var(--torch-glow) at var(--mx, 50%) var(--my, 50%), rgba(255,255,255,0.11), rgba(255,255,255,0.0) 62%);
      mix-blend-mode: screen;
      opacity: 0.85;
    }

    .torch::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(var(--torch-soft) calc(var(--torch-soft) * 0.72) at var(--mx, 50%) var(--my, 50%), rgba(0,0,0,0.0), rgba(0,0,0,0.42) 62%, rgba(0,0,0,0.72) 100%);
      mix-blend-mode: multiply;
      opacity: 0.90;
    }

    .is-night .torch { opacity: 1; }
    .is-night .graffiti-wallpaper { opacity: 0.18; filter: contrast(1.18) saturate(1.08) brightness(0.86); }

    @media (max-width: 560px) {
      .bb-top { flex-direction: column; align-items: flex-start; }
      .bb-top__right { text-align: left; }
      .bb-book { height: min(720px, 78vh); }
      .bb-book__halves { grid-template-columns: 1fr; }
      .bb-book__spine { display: none; }
      .bb-book__halves { top: 10px; }
