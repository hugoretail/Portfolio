---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteNav from '../components/SiteNav.astro';

const INSTAGRAM_URL = 'https://www.instagram.com/';

type GraffPiece = {
  id: string;
  title: string;
  subtitle: string;
  year?: string;
  city?: string;
  src?: string;
  ig?: string;
};

// NOTE: replace `src` with your real photos later (e.g. /assets/graffiti/xxx.jpg)
const pieces: GraffPiece[] = [
  {
    id: 'fresque-1',
    title: 'Fresque 01',
    subtitle: 'Lettrage / souffle / béton',
    year: '2024',
    city: 'Paris',
    src: '/assets/images/dice-face-1.svg'
  },
  {
    id: 'fresque-2',
    title: 'Fresque 02',
    subtitle: 'Chromes / contours / vitesse',
    year: '2023',
    city: 'Montreuil',
    src: '/assets/images/dice-face-2.svg'
  },
  {
    id: 'fresque-3',
    title: 'Fresque 03',
    subtitle: 'Wild-ish / éclats / lignes',
    year: '2022',
    city: 'Lyon',
    src: '/assets/images/dice-face-3.svg'
  },
  {
    id: 'fresque-4',
    title: 'Fresque 04',
    subtitle: 'Pochoir / couches / grain',
    year: '2024',
    city: 'Saint-Ouen',
    src: '/assets/images/dice-face-4.svg'
  },
  {
    id: 'fresque-5',
    title: 'Fresque 05',
    subtitle: 'Coupe / masse / contraste',
    year: '2021',
    city: 'Marseille',
    src: '/assets/images/dice-face-5.svg'
  },
  {
    id: 'fresque-6',
    title: 'Fresque 06',
    subtitle: 'Tag / throw-up / sale',
    year: '2020',
    city: 'Paris',
    src: '/assets/images/dice-face-6.svg'
  }
];
---

<BaseLayout title="Hugo — Graffiti" description="Blackbook interactif (flashlight + pages à tourner).">
  <div id="graffitiPage" class="graffiti-page relative min-h-screen overflow-hidden">
    <div class="pointer-events-none absolute inset-0 bg-graffiti opacity-25" aria-hidden="true"></div>
    <div class="pointer-events-none absolute inset-0 bg-nature opacity-[0.08]" aria-hidden="true"></div>
    <div class="paper-grain" aria-hidden="true"></div>
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="graffiti-wallpaper" aria-hidden="true"></div>
    <div id="torch" class="torch" aria-hidden="true"></div>

    <SiteNav />

    <main class="relative z-10 mx-auto max-w-6xl px-4 pb-16 pt-8">
      <section class="bb-stage" aria-label="Blackbook">
        <div class="bb-top" aria-hidden="true">
          <div class="bb-top__left">GRAFFITI / BLACKBOOK</div>
          <div class="bb-top__right">Flashlight: souris • L: couper • ← →: tourner • Drag: page</div>
        </div>

        <div class="bb-shell">
          <div
            id="bbBook"
            class="bb-book"
            tabindex="0"
            aria-label="Blackbook (L pour couper la lampe, flèches gauche/droite pour tourner)"
          >
            <div class="bb-book__bookmark">
              <a class="bb-ig" href={INSTAGRAM_URL} target="_blank" rel="noreferrer">Instagram ↗</a>
            </div>

            <div class="bb-book__spine" aria-hidden="true"></div>

            <div class="bb-book__halves">
              <div id="bbLeft" class="bb-half bb-half--left" aria-label="Page gauche"></div>
              <div id="bbRight" class="bb-half bb-half--right" aria-label="Page droite"></div>

              <div id="bbFlip" class="bb-flip" aria-hidden="true">
                <div class="bb-flip__face bb-flip__face--front"></div>
                <div class="bb-flip__face bb-flip__face--back"></div>
              </div>
            </div>

            <button id="bbPrev" class="bb-hot bb-hot--prev" type="button" aria-label="Tourner en arrière"></button>
            <button id="bbNext" class="bb-hot bb-hot--next" type="button" aria-label="Tourner la page"></button>
            <div class="bb-hud" aria-hidden="true"><span id="bbCounter"></span></div>
          </div>
        </div>

        <div id="bbTemplates" hidden>
          {pieces.map((p, idx) => (
            <article
              class="bb-sheet"
              data-page={String(idx)}
              data-title={p.title}
              data-subtitle={p.subtitle}
              data-year={p.year ?? ''}
              data-city={p.city ?? ''}
              data-src={p.src ?? ''}
              data-ig={p.ig ?? INSTAGRAM_URL}
            >
              <div class="sheet__top">
                <div class="sheet__num">{String(idx + 1).padStart(2, '0')}</div>
                <div class="sheet__micro">{(p.city ?? '—').toUpperCase()} • {p.year ?? '—'}</div>
              </div>

              <div class="sheet__tag">{p.title}</div>
              <div class="sheet__sub">{p.subtitle}</div>

              <div class="sheet__grid">
                <button class="sheet__media" type="button" data-open aria-label={`Ouvrir ${p.title}`}>
                  {p.src ? <img src={p.src} alt={p.title} loading="lazy" /> : <div class="sheet__ph" />}
                  <span class="sheet__spray" aria-hidden="true"></span>
                </button>

                <div class="sheet__right">
                  <div class="sheet__stamp" aria-hidden="true">SKETCH</div>
                  <div class="sheet__lines" aria-hidden="true"></div>

                  <div class="sheet__blocks">
                    <div class="sheet__block">01 / traits</div>
                    <div class="sheet__block">02 / volumes</div>
                    <div class="sheet__block">03 / fill</div>
                    <div class="sheet__block">04 / outline</div>
                  </div>

                  <div class="sheet__cipher" aria-hidden="true">
                    <div class="cipher__k">invisible ink</div>
                    <div class="cipher__t">HUGO WAS HERE • {p.year ?? '????'} • {p.city ?? '????'}</div>
                  </div>
                </div>
              </div>

              <div class="sheet__foot">
                <a class="sheet__ig" href={p.ig ?? INSTAGRAM_URL} target="_blank" rel="noreferrer">↗ IG</a>
                <div class="sheet__id" aria-hidden="true">#{p.id}</div>
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <dialog id="graffitiModal" class="modal">
      <form method="dialog" class="modal__backdrop">
        <button aria-label="Fermer" class="modal__x" value="close" type="submit">✕</button>
        <div class="modal__panel brutal-border" role="document">
          <div class="modal__head">
            <div>
              <div class="modal__kicker">OUVRIR</div>
              <div id="mTitle" class="modal__title"></div>
              <div id="mSub" class="modal__sub"></div>
            </div>
            <a id="mIG" class="modal__ig" target="_blank" rel="noreferrer">Instagram ↗</a>
          </div>
          <div class="modal__media brutal-border">
            <img id="mImg" alt="" loading="lazy" />
          </div>
          <div class="modal__foot">
            <div class="modal__hint">Esc pour fermer • Clique la photo pour zoom.</div>
            <button class="tool" value="close" type="submit">Fermer</button>
          </div>
        </div>
      </form>
    </dialog>
  </div>

  <script is:inline>
    (() => {
      const page = document.getElementById('graffitiPage');
      const book = document.getElementById('bbBook');
      const left = document.getElementById('bbLeft');
      const right = document.getElementById('bbRight');
      const flip = document.getElementById('bbFlip');
      const torch = document.getElementById('torch');
      const prevPage = document.getElementById('bbPrev');
      const nextPage = document.getElementById('bbNext');
      const counter = document.getElementById('bbCounter');
      const templatesRoot = document.getElementById('bbTemplates');
      const modal = document.getElementById('graffitiModal');
      const mTitle = document.getElementById('mTitle');
      const mSub = document.getElementById('mSub');
      const mImg = document.getElementById('mImg');
      const mIG = document.getElementById('mIG');

      if (!page || !book || !left || !right || !flip || !torch || !templatesRoot) return;

      const prefersReducedMotion = window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches ?? false;
      const STORAGE_KEY = 'graffiti.blackbook.rightPage.v2';

      const sheets = Array.from(templatesRoot.querySelectorAll('.bb-sheet'));
      const flipFront = flip.querySelector('.bb-flip__face--front');
      const flipBack = flip.querySelector('.bb-flip__face--back');

      const clamp = (n, a, b) => Math.max(a, Math.min(b, n));

      const readSavedPage = () => {
        try {
          const raw = window.localStorage.getItem(STORAGE_KEY);
          if (!raw) return 0;
          const n = parseInt(raw, 10);
          return Number.isFinite(n) ? n : 0;
        } catch {
          return 0;
        }
      };

      const writeSavedPage = (n) => {
        try {
          window.localStorage.setItem(STORAGE_KEY, String(n));
        } catch {
          // ignore
        }
      };

      // Lamp / torch
      let lampEnabled = true;
      const setLampEnabled = (on) => {
        lampEnabled = !!on;
        page.classList.toggle('is-night', lampEnabled);
      };
      setLampEnabled(true);

      const setTorchAt = (clientX, clientY) => {
        const r = page.getBoundingClientRect();
        const x = clamp(clientX - r.left, 0, r.width);
        const y = clamp(clientY - r.top, 0, r.height);
        // tiny jitter (hand feel) when lamp is on
        const jx = lampEnabled ? (Math.sin(performance.now() / 110) * 2.2) : 0;
        const jy = lampEnabled ? (Math.cos(performance.now() / 140) * 1.8) : 0;
        torch.style.setProperty('--mx', `${x + jx}px`);
        torch.style.setProperty('--my', `${y + jy}px`);
      };

      // Default torch position
      {
        const r = page.getBoundingClientRect();
        setTorchAt(r.left + r.width * 0.52, r.top + r.height * 0.28);
      }

      let raf = 0;
      let lastMove = null;
      const scheduleTorch = () => {
        if (raf) return;
        raf = window.requestAnimationFrame(() => {
          raf = 0;
          if (!lastMove) return;
          setTorchAt(lastMove.x, lastMove.y);
        });
      };

      window.addEventListener(
        'pointermove',
        (e) => {
          if (e.pointerType === 'touch') return;
          lastMove = { x: e.clientX, y: e.clientY };
          scheduleTorch();
        },
        { passive: true }
      );

      window.addEventListener(
        'pointerdown',
        (e) => {
          if (e.pointerType === 'touch') {
            lastMove = { x: e.clientX, y: e.clientY };
            scheduleTorch();
          }
        },
        { passive: true }
      );

      window.addEventListener('keydown', (e) => {
        if (e.key !== 'l' && e.key !== 'L') return;
        const t = e.target;
        const tag = t?.tagName?.toLowerCase?.();
        if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
        e.preventDefault();
        setLampEnabled(!lampEnabled);
      });

      // Modal
      const openModal = (el) => {
        if (!modal || !mTitle || !mSub || !mImg || !mIG) return;
        const title = el.getAttribute('data-title') || 'Graffiti';
        const subtitle = el.getAttribute('data-subtitle') || '';
        const year = el.getAttribute('data-year') || '';
        const city = el.getAttribute('data-city') || '';
        const src = el.getAttribute('data-src') || '';
        const ig = el.getAttribute('data-ig') || '';
        mTitle.textContent = title;
        mSub.textContent = [subtitle, city, year].filter(Boolean).join(' · ');
        mIG.setAttribute('href', ig || 'https://www.instagram.com/');
        mImg.src = src || '/assets/images/graffiti-wall.svg';
        mImg.alt = title;
        try {
          if (typeof modal.showModal === 'function') modal.showModal();
          else modal.setAttribute('open', 'true');
        } catch {
          modal.setAttribute('open', 'true');
        }
      };

      // Book rendering
      const makeBlank = (side) => {
        const el = document.createElement('div');
        el.className = `bb-blank bb-blank--${side}`;
        if (side === 'left') {
          el.innerHTML = `
            <div class="blank__mark">HUGO</div>
            <div class="blank__sub">BLACKBOOK</div>
            <div class="blank__fine">tourne / éclaire / gratte</div>
          `;
        } else {
          el.innerHTML = `
            <div class="blank__mark">—</div>
            <div class="blank__sub">page vide</div>
            <div class="blank__fine">(pas encore taguée)</div>
          `;
        }
        return el;
      };

      const cloneSheet = (idx) => {
        if (idx < 0 || idx >= sheets.length) return null;
        return sheets[idx].cloneNode(true);
      };

      const mount = (host, node) => {
        host.replaceChildren();
        if (node) host.appendChild(node);
      };

      let rightIdx = clamp(readSavedPage(), 0, Math.max(0, sheets.length - 1));
      let flipping = false;

      const syncCounter = () => {
        if (!counter) return;
        if (sheets.length === 0) {
          counter.textContent = '00/00';
          return;
        }
        counter.textContent = `${String(rightIdx + 1).padStart(2, '0')}/${String(sheets.length).padStart(2, '0')}`;
      };

      const renderSpread = () => {
        const leftIdx = rightIdx - 1;
        const leftNode = leftIdx < 0 ? makeBlank('left') : cloneSheet(leftIdx);
        const rightNode = cloneSheet(rightIdx) ?? makeBlank('right');
        mount(left, leftNode);
        mount(right, rightNode);
        syncCounter();
      };

      const prepareFlipFaces = (frontNode) => {
        if (!flipFront || !flipBack) return;
        flipFront.replaceChildren(frontNode);
        const back = document.createElement('div');
        back.className = 'bb-back';
        back.innerHTML = `
          <div class="bb-back__smudge"></div>
          <div class="bb-back__ghost">INK / BACKSIDE</div>
        `;
        flipBack.replaceChildren(back);
      };

      const runFlip = (dir) => {
        if (prefersReducedMotion) return false;
        if (flipping) return false;
        if (dir === 'next' && rightIdx >= sheets.length - 1) return false;
        if (dir === 'prev' && rightIdx <= 0) return false;
        if (!flipFront || !flipBack) return false;
        const flipDisplay = window.getComputedStyle(flip).display;
        if (flipDisplay === 'none') return false;

        flipping = true;
        book.classList.add('is-flipping');

        const currentLeft = left.firstElementChild?.cloneNode(true) ?? makeBlank('left');
        const currentRight = right.firstElementChild?.cloneNode(true) ?? makeBlank('right');

        flip.classList.remove('is-next', 'is-prev', 'is-turned');
        flip.classList.add(dir === 'next' ? 'is-next' : 'is-prev');
        flip.hidden = false;

        if (dir === 'next') {
          mount(right, cloneSheet(rightIdx + 1) ?? makeBlank('right'));
          prepareFlipFaces(currentRight);
        } else {
          mount(left, (rightIdx - 2) < 0 ? makeBlank('left') : cloneSheet(rightIdx - 2));
          mount(right, cloneSheet(rightIdx - 1) ?? makeBlank('right'));
          prepareFlipFaces(currentLeft);
        }

        void flip.offsetWidth;
        flip.classList.add('is-turned');

        const done = () => {
          flip.hidden = true;
          flip.classList.remove('is-next', 'is-prev', 'is-turned');
          book.classList.remove('is-flipping');
          rightIdx = dir === 'next' ? rightIdx + 1 : rightIdx - 1;
          rightIdx = clamp(rightIdx, 0, Math.max(0, sheets.length - 1));
          writeSavedPage(rightIdx);
          renderSpread();
          flipping = false;
        };

        flip.addEventListener(
          'transitionend',
          (e) => {
            if (e.target !== flip) return;
            done();
          },
          { once: true }
        );

        window.setTimeout(() => {
          if (!flipping) return;
          done();
        }, 900);

        return true;
      };

      const turnNext = () => {
        if (runFlip('next')) return;
        if (rightIdx < sheets.length - 1) {
          rightIdx++;
          writeSavedPage(rightIdx);
          renderSpread();
        }
      };

      const turnPrev = () => {
        if (runFlip('prev')) return;
        if (rightIdx > 0) {
          rightIdx--;
          writeSavedPage(rightIdx);
          renderSpread();
        }
      };

      renderSpread();
      flip.hidden = true;

      prevPage?.addEventListener('click', () => {
        if (!modal?.open) turnPrev();
      });
      nextPage?.addEventListener('click', () => {
        if (!modal?.open) turnNext();
      });

      const isInteractiveTarget = (t) => !!t?.closest?.('a, button, input, textarea, select, [data-open]');

      book.addEventListener('click', (e) => {
        const btn = e.target?.closest?.('[data-open]');
        if (btn) {
          const sheetEl = btn.closest('.bb-sheet');
          if (sheetEl) openModal(sheetEl);
          return;
        }
        if (isInteractiveTarget(e.target)) return;
        const r = book.getBoundingClientRect();
        const x = e.clientX - r.left;
        if (x > r.width * 0.52) turnNext();
        else if (x < r.width * 0.48) turnPrev();
      });

      let drag = null;
      book.addEventListener('pointerdown', (e) => {
        if (modal?.open) return;
        if (isInteractiveTarget(e.target)) return;
        drag = { x0: e.clientX, y0: e.clientY };
        try {
          book.setPointerCapture(e.pointerId);
        } catch {}
      });
      book.addEventListener('pointermove', (e) => {
        if (!drag) return;
        const dx = e.clientX - drag.x0;
        const dy = e.clientY - drag.y0;
        if (Math.abs(dy) > 120) return;
        if (dx < -90) {
          drag = null;
          turnNext();
        }
        if (dx > 90) {
          drag = null;
          turnPrev();
        }
      });
      book.addEventListener('pointerup', () => {
        drag = null;
      });
      book.addEventListener('pointercancel', () => {
        drag = null;
      });

      const onTurnKey = (e) => {
        if (modal?.open) return;
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          turnPrev();
        }
        if (e.key === 'ArrowRight') {
          e.preventDefault();
          turnNext();
        }
      };
      book.addEventListener('keydown', onTurnKey);
      window.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
        const t = e.target;
        const tag = t?.tagName?.toLowerCase?.();
        if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
        onTurnKey(e);
      });
    })();
  </script>

  <style>
    .graffiti-page {
      --ink: rgba(0,0,0,0.92);
      --paper: #efe7d2;
      --paper2: #e3d8bf;
      --accent: #ff0000;
      --neon: #ffe600;
      --steel: rgba(246,246,246,0.65);
      --torch-hole: 420px;
      --torch-soft: 720px;
      --torch-glow: 320px;
    }

    .graffiti-wallpaper {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        url('/assets/images/graffiti-texture.svg') center / cover no-repeat,
        radial-gradient(1100px 800px at 12% 22%, rgba(255, 0, 0, 0.09), transparent 62%),
        radial-gradient(900px 780px at 85% 30%, rgba(255, 230, 0, 0.05), transparent 60%),
        radial-gradient(1100px 800px at 68% 84%, rgba(0, 209, 255, 0.05), transparent 65%);
      opacity: 0.36;
      mix-blend-mode: overlay;
      filter: contrast(1.12) saturate(1.18);
    }

    .bb-stage { margin-top: 18px; }
    .bb-top {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      font-weight: 900;
      font-size: 10px;
      letter-spacing: 0.34em;
      text-transform: uppercase;
      color: rgba(246,246,246,0.55);
    }
    .bb-top__left { color: rgba(255,230,0,0.62); }
    .bb-top__right { text-align: right; }

    .bb-shell {
      margin-top: 16px;
      display: grid;
      place-items: center;
      min-height: min(860px, 78vh);
    }

    .bb-book {
      position: relative;
      width: min(980px, 94vw);
      height: min(620px, 70vh);
      border: 2px solid rgba(246,246,246,0.45);
      box-shadow: 18px 18px 0 rgba(0,0,0,0.62);
      background:
        radial-gradient(800px 380px at 50% 110%, rgba(255,0,0,0.05), transparent 65%),
        radial-gradient(900px 520px at 0% 0%, rgba(0,209,255,0.04), transparent 60%),
        rgba(0,0,0,0.38);
      outline: none;
      perspective: 1600px;
      transform-style: preserve-3d;
      isolation: isolate;
    }

    .bb-book::before {
      content: '';
      position: absolute;
      inset: 10px;
      border: 2px solid rgba(246,246,246,0.18);
      pointer-events: none;
    }

    .bb-book__spine {
      position: absolute;
      left: calc(50% - 14px);
      top: 0;
      bottom: 0;
      width: 28px;
      background:
        linear-gradient(90deg, rgba(0,0,0,0.75), rgba(255,255,255,0.08), rgba(0,0,0,0.72)),
        repeating-linear-gradient(0deg, rgba(255,230,0,0.10) 0 2px, transparent 2px 10px);
      opacity: 0.9;
      mix-blend-mode: multiply;
      pointer-events: none;
      transform: translateZ(8px);
    }

    .bb-book__bookmark {
      position: absolute;
      right: 18px;
      top: -12px;
      z-index: 6;
      transform: translateZ(22px);
    }

    .bb-ig {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 12px;
      border: 2px solid rgba(255,230,0,0.65);
      background: rgba(0,0,0,0.60);
      color: rgba(255,230,0,0.90);
      font-weight: 900;
      font-size: 11px;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      box-shadow: 8px 8px 0 rgba(0,0,0,0.60);
    }

    .bb-book__halves {
      position: absolute;
      left: 16px;
      right: 16px;
      top: 16px;
      bottom: 16px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      transform: translateZ(14px);
    }

    .bb-half {
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(1200px 800px at 20% 30%, rgba(0,0,0,0.06), transparent 60%),
        linear-gradient(180deg, var(--paper), var(--paper2));
      color: var(--ink);
      padding: 18px 18px 14px;
      filter: contrast(1.05) saturate(1.05);
    }

    .bb-half::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        repeating-linear-gradient(0deg, rgba(0,0,0,0.04) 0 1px, transparent 1px 28px),
        radial-gradient(700px 500px at 50% 40%, rgba(0,0,0,0.10), transparent 60%);
      opacity: 0.34;
      pointer-events: none;
      mix-blend-mode: multiply;
    }

    .bb-half--left { border-right: 2px solid rgba(0,0,0,0.12); }
    .bb-half--right { border-left: 2px solid rgba(0,0,0,0.10); }
    .bb-half > * { position: relative; z-index: 1; }

    .bb-hot {
      position: absolute;
      inset: 0;
      width: 50%;
      background: transparent;
      border: none;
      padding: 0;
      opacity: 0;
      cursor: pointer;
      z-index: 7;
    }

    .bb-hot--prev { left: 0; cursor: w-resize; }
    .bb-hot--next { right: 0; cursor: e-resize; }

    .bb-book:hover .bb-hot { opacity: 0.05; }

    .bb-hot:focus-visible {
      opacity: 1;
      outline: 2px solid rgba(255,230,0,0.65);
      outline-offset: 6px;
    }

    .bb-hud {
      position: absolute;
      left: 18px;
      bottom: 18px;
      z-index: 6;
      font-weight: 900;
