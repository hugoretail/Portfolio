---
import BaseLayout from '../layouts/BaseLayout.astro';
import TimelineFrise from '../components/TimelineFrise.svelte';
import { withBase } from '../lib/withBase';
---

<BaseLayout title="Frise — Hugo Retail" description="Frise chronologique" showThread={false}>
	<main class="relative min-h-screen overflow-hidden">
		<div class="absolute inset-0 bg-graffiti opacity-[0.18]" aria-hidden="true"></div>
		<div class="absolute inset-0 bg-nature opacity-[0.10]" aria-hidden="true"></div>
		<div class="paper-grain" aria-hidden="true"></div>
		<div class="noise-overlay" aria-hidden="true"></div>

		<a class="bb-backbtn brutal-border" href={withBase('/moi')} aria-label="Retour à /moi" title="Retour">
			<span aria-hidden="true">←</span>
		</a>

		<section class="relative z-10">
			<TimelineFrise client:load />
		</section>
	</main>
</BaseLayout>

<style>
	.bb-backbtn {
		position: fixed;
		top: 70px;
		left: 18px;
		z-index: 60;
		display: inline-grid;
		place-items: center;
		width: 44px;
		height: 44px;
		background: rgba(0, 0, 0, 0.6);
		border: 2px solid rgba(246, 246, 246, 0.45);
		color: rgba(246, 246, 246, 0.88);
		font-weight: 900;
		font-size: 18px;
		line-height: 1;
		text-decoration: none;
		box-shadow: 8px 8px 0 rgba(0, 0, 0, 0.6);
		transition: background 140ms ease, transform 140ms ease;
	}

	.bb-backbtn:hover {
		background: rgba(0, 0, 0, 0.72);
		transform: translateY(-1px);
	}

	@media (max-width: 860px) {
		.bb-backbtn {
			top: 60px;
			left: 12px;
			width: 40px;
			height: 40px;
		}
	}
</style>
