---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignatureTool from '../components/SignatureTool.svelte';
import Dice3D from '../components/Dice3D.svelte';
import ExplorerButton from '../components/ExplorerButton.svelte';
import QRCode from '../components/QRCode.svelte';
---

<BaseLayout title="Hugo">
	<main class="relative min-h-screen overflow-hidden">
		<div class="absolute inset-0 bg-graffiti opacity-20" aria-hidden="true"></div>
		<div class="absolute -right-24 top-16 w-[520px] opacity-50 md:opacity-60" aria-hidden="true">
			<img src="/assets/images/leaves.svg" alt="" loading="lazy" />
		</div>
		<div class="absolute -left-40 bottom-10 w-[560px] rotate-6 opacity-35" aria-hidden="true">
			<img src="/assets/images/leaves.svg" alt="" loading="lazy" />
		</div>
		<div class="noise-overlay" aria-hidden="true"></div>

		<section class="relative z-10 mx-auto max-w-6xl px-4 py-10 md:py-16">
			<header class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
				<div>
					<h1 class="font-display text-7xl leading-none md:text-9xl">Hugo</h1>
					<p class="mt-3 max-w-xl font-hand text-2xl text-[color:var(--muted)]">
						Street-art, nature, hip-hop, IA — un fil rouge, des impacts.
					</p>
				</div>

				<div class="flex items-center gap-4">
					<ExplorerButton client:load href="/graffiti" label="Explorer" />
				</div>
			</header>

			<div class="mt-10 grid gap-8 lg:grid-cols-2">
				<SignatureTool client:load />
				<Dice3D client:load />
			</div>

			<div class="mt-12 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
				<div class="brutal-border max-w-2xl bg-black/40 p-4">
					<div class="font-display text-2xl tracking-wide">Fil rouge</div>
					<p class="mt-2 font-hand text-2xl text-[color:var(--muted)]">
						Chaque section est une pièce — le dé choisit, la main signe, le fil relie.
					</p>
				</div>

				<QRCode client:load url="LIEN_SPOTIFY_PLAYLIST" />
			</div>
		</section>
	</main>
</BaseLayout>
