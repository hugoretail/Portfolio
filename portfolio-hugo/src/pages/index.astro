---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignatureAuto from '../components/SignatureAuto.svelte';
import Dice3D from '../components/Dice3D.svelte';
import ExplorerButton from '../components/ExplorerButton.svelte';
import QRCode from '../components/QRCode.svelte';
import { withBase } from '../lib/withBase';
---

<BaseLayout title="Hugo Retail">
	<script is:inline>
		// Homepage intro animation state (self-cleaning).
		(() => {
			try {
				const root = document.documentElement;
				const reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				if (reduced) {
					root.classList.add('intro-done');
					return;
				}
				root.classList.add('intro-running');
				window.addEventListener(
					'load',
					() => {
						const TOTAL_MS = 3200; // draw + reveal
						window.setTimeout(() => {
							root.classList.add('intro-done');
							root.classList.remove('intro-running');
						}, TOTAL_MS);
						window.setTimeout(() => {
							document.getElementById('homeIntro')?.remove();
						}, TOTAL_MS + 700);
					},
					{ once: true }
				);
			} catch {
				document.documentElement.classList.add('intro-done');
				document.documentElement.classList.remove('intro-running');
			}
		})();
	</script>

	<div id="homeIntro" class="home-intro" aria-hidden="true">
		<svg class="home-intro__svg" viewBox="0 0 120 120" role="presentation" focusable="false">
			<circle class="home-intro__ring" cx="60" cy="60" r="44" />
		</svg>
	</div>

	<main class="home-main relative min-h-screen overflow-hidden">
		<div class="pointer-events-none absolute inset-0 bg-graffiti opacity-[0.10]" aria-hidden="true"></div>
		<div class="pointer-events-none absolute inset-0 bg-nature opacity-[0.06]" aria-hidden="true"></div>
		<div class="paper-grain" aria-hidden="true"></div>
		<div class="noise-overlay" aria-hidden="true"></div>

		<section class="relative z-10 mx-auto max-w-6xl px-4 py-10 md:py-16">
			<header class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
				<div>
					<h1 class="font-display text-7xl leading-none md:text-9xl">Hugo Retail</h1>
					<p class="mt-3 max-w-xl font-hand text-2xl text-[color:var(--muted)]">
						Mon portfolio, explorez donc !
					</p>
				</div>

				<div class="flex items-center gap-4">
					<ExplorerButton client:load href={withBase('/moi')} label="Explorer" />
				</div>
			</header>

			<div class="mt-10 grid gap-8 lg:grid-cols-2">
				<SignatureAuto client:load src={withBase('/assets/images/signature.gif')} />
				<Dice3D client:load />
			</div>

			<section class="mt-10 brutal-border bg-black/35 p-5">
				<div class="flex flex-wrap items-baseline justify-between gap-3">
					<div class="font-display text-2xl tracking-wide">Découvrir mon profil</div>
					<div class="font-black uppercase tracking-widest text-xs text-[color:var(--muted)]">micro-manifeste</div>
				</div>
				<p class="mt-3 font-hand text-3xl leading-snug text-[color:var(--fg)]">
					Sous une simple créativité.
					<span class="mx-2 text-[color:var(--red-thread)]">/</span>
					Coder pour la nature.
					<span class="mx-2 text-[color:var(--red-thread)]">/</span>
					Et avec imagination.
				</p>
				<p class="mt-2 max-w-3xl font-hand text-2xl text-[color:var(--muted)]">
					Ce portfolio présente les différentes facettes de mon profil.
				</p>
			</section>

			<div class="mt-12 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
				<div class="brutal-border max-w-2xl bg-black/40 p-4">
					<div class="font-display text-2xl tracking-wide">Fil rouge</div>
					<p class="mt-2 font-hand text-2xl text-[color:var(--muted)]">
						Pour suivre chronologiquement mon histoire, visitez le fil rouge !
					</p>
				</div>

				<div class="brutal-border relative bg-white/90 p-4 text-black">
					<div class="absolute -left-2 -top-2 brutal-border-red bg-[color:var(--acid-yellow)] px-3 py-2 text-xs font-black uppercase tracking-widest">
						LinkedIn
					</div>
					<div class="pt-6">
						<div class="mt-4">
							<QRCode client:load url="https://www.linkedin.com/in/hugo-retail/" />
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<style>
		/* Main content reveal */
		.home-main {
			opacity: 1;
			transform: none;
			transition: opacity 650ms ease, transform 650ms ease;
		}
		html.intro-running .home-main {
			opacity: 0;
			transform: translateY(10px);
		}

		/* Fullscreen intro overlay */
		.home-intro {
			position: fixed;
			inset: 0;
			z-index: 9999;
			display: none;
			place-items: center;
			background: #000;
			pointer-events: none;
			opacity: 1;
			clip-path: circle(150% at 50% 50%);
			will-change: clip-path, opacity;
		}
		html.intro-running .home-intro {
			display: grid;
			animation: homeIntroReveal 900ms cubic-bezier(0.2, 0.9, 0.2, 1) 2300ms forwards;
		}
		@keyframes homeIntroReveal {
			to {
				clip-path: circle(0% at 50% 50%);
				opacity: 0;
			}
		}

		.home-intro__svg {
			width: min(46vmin, 320px);
			height: auto;
			filter: drop-shadow(0 0 14px rgba(246, 246, 246, 0.10));
		}
		.home-intro__ring {
			fill: none;
			stroke: rgba(246, 246, 246, 0.92);
			stroke-width: 2.25;
			stroke-linecap: round;
			stroke-dasharray: 276;
			stroke-dashoffset: 276;
			animation: homeIntroDraw 2100ms cubic-bezier(0.2, 0.8, 0.2, 1) 120ms forwards;
		}
		@keyframes homeIntroDraw {
			to {
				stroke-dashoffset: 0;
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.home-intro {
				display: none !important;
			}
			.home-main {
				transition: none;
			}
		}
	</style>
</BaseLayout>
