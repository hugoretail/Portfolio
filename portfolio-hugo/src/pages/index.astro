---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignatureAuto from '../components/SignatureAuto.svelte';
import Dice3D from '../components/Dice3D.svelte';
import ExplorerButton from '../components/ExplorerButton.svelte';
import QRCode from '../components/QRCode.svelte';
import { withBase } from '../lib/withBase';
---

<BaseLayout title="Hugo Retail">
	<script is:inline>
		// Homepage intro animation state (self-cleaning).
		(() => {
			try {
				const root = document.documentElement;
				const reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				if (reduced) {
					root.classList.add('intro-done');
					return;
				}
				root.classList.add('intro-running');
				window.addEventListener(
					'load',
					() => {
						const TOTAL_MS = 3200; // draw + reveal
						window.setTimeout(() => {
							root.classList.add('intro-done');
							root.classList.remove('intro-running');
						}, TOTAL_MS);
						window.setTimeout(() => {
							document.getElementById('homeIntro')?.remove();
						}, TOTAL_MS + 700);
					},
					{ once: true }
				);
			} catch {
				document.documentElement.classList.add('intro-done');
				document.documentElement.classList.remove('intro-running');
			}
		})();
	</script>

	<div id="homeIntro" class="home-intro" aria-hidden="true">
		<svg class="home-intro__svg" viewBox="0 0 120 120" role="presentation" focusable="false">
			<circle class="home-intro__ring" cx="60" cy="60" r="44" />
		</svg>
	</div>

	<nav class="qa-float" aria-label="Accès rapide">
		<div class="qa-float__root">
			<button class="qa-float__label" type="button" aria-haspopup="menu">Accès rapide</button>
			<div class="qa-float__menu" role="list">
				<a class="qa-float__link" href={withBase('/informatique')} role="listitem">Informatique</a>
				<a class="qa-float__link" href={withBase('/graffiti')} role="listitem">Graffiti</a>
				<a class="qa-float__link" href={withBase('/environnement')} role="listitem">Environnement</a>
				<a class="qa-float__link" href={withBase('/frise')} role="listitem">Frise</a>
				<a class="qa-float__link" href={withBase('/hiphop')} role="listitem">Hip-hop</a>
			</div>
		</div>
	</nav>

	<main class="home-main relative min-h-screen overflow-hidden">
		<div class="pointer-events-none absolute inset-0 bg-graffiti opacity-[0.10]" aria-hidden="true"></div>
		<div class="pointer-events-none absolute inset-0 bg-nature opacity-[0.06]" aria-hidden="true"></div>
		<div class="paper-grain" aria-hidden="true"></div>
		<div class="noise-overlay" aria-hidden="true"></div>

		<section class="relative z-10 mx-auto max-w-6xl px-4 py-10 md:py-16">
			<header class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
				<div>
					<h1 class="font-display text-7xl leading-none md:text-9xl">Hugo Retail</h1>
					<p class="mt-3 max-w-xl font-hand text-2xl text-[color:var(--muted)]">
						Portfolio v2 - 2026
					</p>
				</div>

				<div class="flex flex-col items-start gap-3 md:items-end">
					<ExplorerButton client:load href={withBase('/moi')} label="Explorer" />
				</div>
			</header>

			<div class="mt-10 grid gap-8 lg:grid-cols-2">
				<SignatureAuto client:load src={withBase('/assets/images/signature.gif')} />
				<Dice3D client:load />
			</div>

			<section class="mt-10 brutal-border bg-black/35 p-5">
				<div class="flex flex-wrap items-baseline justify-between gap-3">
					<div class="font-display text-2xl tracking-wide">Mon profil, feat :</div>
				</div>
				<p class="mt-3 font-hand text-3xl leading-snug text-[color:var(--fg)]">
					La Créativité
					<span class="mx-2 text-[color:var(--red-thread)]">/</span>
					La Passion
					<span class="mx-2 text-[color:var(--red-thread)]">/</span>
					L'Imagination
				</p>
				<p class="mt-2 max-w-3xl font-hand text-2xl text-[color:var(--muted)]">
					Ce portfolio présente les différentes facettes de mon profil.
				</p>
			</section>

			<div class="mt-12 flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
				<div class="brutal-border max-w-2xl bg-black/40 p-4">
					<div class="font-display text-2xl tracking-wide">Fil rouge</div>
					<p class="mt-2 font-hand text-2xl text-[color:var(--muted)]">
						Pour suivre chronologiquement mon histoire, visitez le fil rouge !
					</p>
				</div>

				<div class="brutal-border relative bg-white/90 p-4 text-black">
					<div class="absolute -left-2 -top-2 brutal-border-red bg-[color:var(--acid-yellow)] px-3 py-2 text-xs font-black uppercase tracking-widest">
						LinkedIn
					</div>
					<div class="pt-6">
						<div class="mt-4">
							<QRCode client:load url="https://www.linkedin.com/in/hugo-retail/" />
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>

	<style>
		/* Main content reveal */
		.home-main {
			opacity: 1;
			transform: none;
			transition: opacity 650ms ease, transform 650ms ease;
		}
		html.intro-running .home-main {
			opacity: 0;
			transform: translateY(10px);
		}

		/* Fullscreen intro overlay */
		.home-intro {
			position: fixed;
			inset: 0;
			z-index: 9999;
			display: none;
			place-items: center;
			background: #000;
			pointer-events: none;
			opacity: 1;
			clip-path: circle(150% at 50% 50%);
			will-change: clip-path, opacity;
		}
		html.intro-running .home-intro {
			display: grid;
			animation: homeIntroReveal 900ms cubic-bezier(0.2, 0.9, 0.2, 1) 2300ms forwards;
		}
		@keyframes homeIntroReveal {
			to {
				clip-path: circle(0% at 50% 50%);
				opacity: 0;
			}
		}

		.home-intro__svg {
			width: min(46vmin, 320px);
			height: auto;
			filter: drop-shadow(0 0 14px rgba(246, 246, 246, 0.10));
		}
		.home-intro__ring {
			fill: none;
			stroke: rgba(246, 246, 246, 0.92);
			stroke-width: 2.25;
			stroke-linecap: round;
			stroke-dasharray: 276;
			stroke-dashoffset: 276;
			animation: homeIntroDraw 2100ms cubic-bezier(0.2, 0.8, 0.2, 1) 120ms forwards;
		}
		@keyframes homeIntroDraw {
			to {
				stroke-dashoffset: 0;
			}
		}

		@media (prefers-reduced-motion: reduce) {
			.home-intro {
				display: none !important;
			}
			.home-main {
				transition: none;
			}
		}

		/* Fixed top quick access (hover to reveal) */
		.qa-float {
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			display: flex;
			justify-content: center;
			z-index: 70;
			pointer-events: none;
			padding: 0;
		}
		.qa-float__root {
			position: relative;
			pointer-events: auto;
			padding-top: 0;
		}
		/* Hover-bridge so the menu doesn't disappear while moving cursor */
		.qa-float__root::after {
			content: '';
			position: absolute;
			left: -18px;
			right: -18px;
			top: 100%;
			height: 14px;
			background: transparent;
		}
		.qa-float__label {
			position: relative;
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 10px 14px 9px;
			border: 2px solid rgba(246, 246, 246, 0.24);
			border-top: 0;
			background: rgba(0, 0, 0, 0.22);
			color: rgba(246, 246, 246, 0.78);
			text-transform: uppercase;
			font-weight: 900;
			font-size: 11px;
			letter-spacing: 0.22em;
			backdrop-filter: blur(2px);
			box-shadow: none;
			user-select: none;
			clip-path: polygon(0 0, 100% 0, calc(100% - 12px) 100%, 12px 100%);
		}
		.qa-float__label::after {
			content: '';
			position: absolute;
			left: 10px;
			right: 10px;
			bottom: -2px;
			height: 2px;
			background: rgba(255, 61, 61, 0.65);
			transform-origin: left;
			transform: scaleX(0);
			transition: transform 140ms ease;
		}
		.qa-float__label:hover,
		.qa-float__label:focus-visible {
			border-color: rgba(255, 230, 0, 0.55);
			color: rgba(246, 246, 246, 0.92);
		}
		.qa-float__root:hover .qa-float__label::after,
		.qa-float__root:focus-within .qa-float__label::after {
			transform: scaleX(1);
		}
		.qa-float__menu {
			position: absolute;
			top: 100%;
			left: 50%;
			transform: translate(-50%, -6px);
			width: min(340px, 92vw);
			padding: 12px;
			border: 2px solid rgba(246, 246, 246, 0.22);
			border-top: 0;
			background: rgba(0, 0, 0, 0.28);
			box-shadow: none;
			backdrop-filter: blur(2px);
			opacity: 0;
			visibility: hidden;
			pointer-events: none;
			transition: opacity 140ms ease, transform 140ms ease;
		}
		.qa-float__root:hover .qa-float__menu,
		.qa-float__root:focus-within .qa-float__menu {
			opacity: 1;
			visibility: visible;
			pointer-events: auto;
			transform: translate(-50%, 0);
		}
		.qa-float__link {
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 10px 12px;
			border: 2px solid rgba(246, 246, 246, 0.24);
			background: rgba(0, 0, 0, 0.36);
			color: rgba(246, 246, 246, 0.88);
			text-decoration: none;
			font-weight: 900;
			font-size: 12px;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			transition: transform 140ms ease, background 140ms ease, border-color 140ms ease;
		}
		.qa-float__link + .qa-float__link {
			margin-top: 8px;
		}
		.qa-float__link:hover,
		.qa-float__link:focus-visible {
			background: rgba(0, 0, 0, 0.60);
			border-color: rgba(255, 230, 0, 0.55);
			transform: translateY(-1px);
		}

		@media (max-width: 480px) {
			.qa-float {
				padding-top: 0;
			}
			.qa-float__label {
				padding: 9px 12px 8px;
				font-size: 10px;
			}
		}
	</style>
</BaseLayout>
